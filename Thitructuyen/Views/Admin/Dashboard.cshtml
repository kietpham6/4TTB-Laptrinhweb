@{
    ViewData["Title"] = "Dashboard Admin";
}
<div class="pro-page-title">
    <div>
        <h2>🛡️ Dashboard Admin</h2>
        <p>Dữ liệu thật từ hệ thống: người dùng, đề thi, lượt thi, điểm số và cảnh báo gian lận.</p>
    </div>
    <a class="btn btn-outline-primary" asp-controller="Admin" asp-action="ActivityLogs"><i class="bi-shield-check me-1"></i> Audit Log</a>
</div>

<div class="row g-4 mb-4">
    <div class="col-md-6 col-xl-3"><div class="metric-card"><div class="metric-icon"><i class="bi-people"></i></div><div class="metric-value" data-k="totalUsers">@ViewBag.TotalUsers</div><div class="metric-label">Tổng người dùng</div></div></div>
    <div class="col-md-6 col-xl-3"><div class="metric-card"><div class="metric-icon"><i class="bi-file-earmark-text"></i></div><div class="metric-value" data-k="totalExams">@ViewBag.TotalExams</div><div class="metric-label">Tổng kỳ thi</div></div></div>
    <div class="col-md-6 col-xl-3"><div class="metric-card"><div class="metric-icon"><i class="bi-pencil-square"></i></div><div class="metric-value" data-k="totalAttempts">@ViewBag.TotalAttempts</div><div class="metric-label">Tổng lượt thi</div></div></div>
    <div class="col-md-6 col-xl-3"><div class="metric-card"><div class="metric-icon"><i class="bi-shield-exclamation"></i></div><div class="metric-value" data-k="violations">@ViewBag.Violations</div><div class="metric-label">Vi phạm Anti-cheat</div></div></div>
</div>

<div class="row g-4 mb-4">
    <div class="col-xl-8"><div class="chart-card"><h5 class="mb-3">📈 Lượt thi & điểm TB 7 ngày gần nhất</h5><canvas id="attemptChart" height="120"></canvas></div></div>
    <div class="col-xl-4"><div class="chart-card"><h5 class="mb-3">👥 Cơ cấu vai trò</h5><canvas id="roleChart" height="170"></canvas></div></div>
</div>

<div class="row g-4">
    <div class="col-xl-7"><div class="chart-card"><h5 class="mb-3">📚 Thống kê theo môn học</h5><div class="table-responsive"><table class="table table-hover align-middle"><thead><tr><th>Môn học</th><th>Lượt thi</th><th>Điểm TB</th></tr></thead><tbody id="subjectStats"></tbody></table></div></div></div>
    <div class="col-xl-5"><div class="chart-card"><h5 class="mb-3">🧾 Hoạt động mới nhất</h5><div id="latestLogs" class="vstack gap-2"></div></div></div>
</div>

@section Scripts {
<script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
<script>
let attemptChart, roleChart;
fetch('/api/dashboard/admin').then(r=>{ if(!r.ok) throw new Error('Không tải được API dashboard'); return r.json(); }).then(data=>{
    document.querySelectorAll('[data-k]').forEach(el=> el.textContent = data[el.dataset.k] ?? 0);
    if(window.Chart){
        attemptChart = new Chart(document.getElementById('attemptChart'), {type:'bar', data:{labels:(data.chart||[]).map(x=>x.label), datasets:[{label:'Lượt thi', data:(data.chart||[]).map(x=>x.attempts)}, {label:'Điểm TB', type:'line', data:(data.chart||[]).map(x=>x.avgScore), yAxisID:'y1'}]}, options:{responsive:true, scales:{y:{beginAtZero:true}, y1:{position:'right', min:0, max:10, grid:{drawOnChartArea:false}}}}});
        roleChart = new Chart(document.getElementById('roleChart'), {type:'doughnut', data:{labels:(data.roleStats||[]).map(x=>x.role), datasets:[{data:(data.roleStats||[]).map(x=>x.count)}]}, options:{responsive:true}});
    }
    document.getElementById('subjectStats').innerHTML = (data.subjectStats||[]).map(x=>`<tr><td>${x.subject}</td><td><span class="badge bg-info">${x.attempts}</span></td><td><b>${x.avgScore}</b>/10</td></tr>`).join('') || '<tr><td colspan="3" class="text-center text-muted py-4">Chưa có dữ liệu</td></tr>';
    document.getElementById('latestLogs').innerHTML = (data.latestLogs||[]).map(x=>`<div class="border rounded-3 p-2"><b>${x.action}</b><br><span class="text-muted small">${x.detail}</span><br><small>${x.createdAt} • ${x.ipAddress||''}</small></div>`).join('') || '<div class="text-muted">Chưa có log</div>';
}).catch(err=>{
    document.getElementById('subjectStats').innerHTML = `<tr><td colspan="3" class="text-danger text-center py-4">${err.message}</td></tr>`;
    document.getElementById('latestLogs').innerHTML = '<div class="text-danger">Không tải được dữ liệu API. Kiểm tra database/migration.</div>';
});
</script>
}
