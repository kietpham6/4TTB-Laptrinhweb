@{
    ViewData["Title"] = "Quản lý người dùng";
}

<section class="intro-section section-padding">
    <div class="container">
        <div class="d-flex justify-content-between align-items-center mb-4"
             style="margin-top:100px;">
            <div>
                <h2>👥 Quản lý người dùng</h2>
                <p class="text-muted">Thêm, sửa, xóa và phân quyền người dùng</p>
            </div>
            <button class="btn btn-primary" data-bs-toggle="modal" data-bs-target="#addUserModal">
                <i class="bi-person-plus me-2"></i>Thêm người dùng
            </button>
        </div>

        <!-- Bộ lọc -->
        <div class="card border-0 shadow-sm rounded-4 mb-4">
            <div class="card-body p-4">
                <div class="row g-3">
                    <div class="col-md-3">
                        <select class="form-select" id="filterRole" onchange="loadUsers()">
                            <option value="">Tất cả vai trò</option>
                            <option value="Admin">Admin</option>
                            <option value="Teacher">Teacher</option>
                            <option value="Student">Student</option>
                        </select>
                    </div>
                    <div class="col-md-3">
                        <select class="form-select" id="filterStatus" onchange="loadUsers()">
                            <option value="">Tất cả trạng thái</option>
                            <option value="Active">Hoạt động</option>
                            <option value="Locked">Khóa</option>
                        </select>
                    </div>
                    <div class="col-md-4">
                        <input type="text" id="searchInput" class="form-control" placeholder="Tìm kiếm theo tên hoặc email..." onkeyup="loadUsers()">
                    </div>
                    <div class="col-md-2">
                        <button class="btn btn-outline-secondary w-100" onclick="resetFilters()">
                            <i class="bi-arrow-repeat me-1"></i>Reset
                        </button>
                    </div>
                </div>
            </div>
        </div>

        <!-- Bảng người dùng -->
        <div class="card border-0 shadow-sm rounded-4">
            <div class="card-body p-0">
                <div class="table-responsive">
                    <table class="table table-hover mb-0">
                        <thead class="bg-light">
                            <tr>
                                <th><input type="checkbox" id="selectAll" onclick="toggleSelectAll()"></th>
                                <th>ID</th>
                                <th>Avatar</th>
                                <th>Tài khoản</th>
                                <th>Họ tên</th>
                                <th>Email</th>
                                <th>Vai trò</th>
                                <th>Trạng thái</th>
                                <th>Ngày tạo</th>
                                <th class="text-center">Thao tác</th>
                            </tr>
                        </thead>
                        <tbody id="userTableBody">
                            <tr>
                                <td colspan="10" class="text-center py-4">
                                    <div class="spinner-border text-primary" role="status">
                                        <span class="visually-hidden">Loading...</span>
                                    </div>
                                </td>
                            </tr>
                        </tbody>
                    </table>
                </div>
            </div>
        </div>

        <!-- Bulk actions -->
        <div class="row mt-3">
            <div class="col-12">
                <div class="d-flex justify-content-between align-items-center">
                    <div id="selectedCount" class="text-muted">Đã chọn 0 người dùng</div>
                    <div>
                        <button class="btn btn-outline-warning me-2" onclick="bulkLock()" style="display: none;" id="bulkLockBtn">
                            <i class="bi-lock me-1"></i>Khóa
                        </button>
                        <button class="btn btn-outline-danger" onclick="bulkDelete()" style="display: none;" id="bulkDeleteBtn">
                            <i class="bi-trash me-1"></i>Xóa
                        </button>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>

<!-- Modal Thêm người dùng -->
<div class="modal fade" id="addUserModal" tabindex="-1" >
    <div class="modal-dialog" style="margin-top:120px;">
        <div class="modal-content rounded-4" >
            <div class="modal-header border-0">
                <h5 class="modal-title"><i class="bi-person-plus-fill me-2"></i>Thêm người dùng mới</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body">
                <form id="addUserForm">
                    <div class="mb-3">
                        <label class="form-label fw-semibold">Tên đăng nhập</label>
                        <input type="text" id="addUsername" class="form-control" required>
                    </div>
                    <div class="mb-3">
                        <label class="form-label fw-semibold">Mật khẩu</label>
                        <input type="password" id="addPassword" class="form-control" required>
                    </div>
                    <div class="mb-3">
                        <label class="form-label fw-semibold">Họ và tên</label>
                        <input type="text" id="addFullname" class="form-control" required>
                    </div>
                    <div class="mb-3">
                        <label class="form-label fw-semibold">Email</label>
                        <input type="email" id="addEmail" class="form-control" required>
                    </div>
                    <div class="mb-3">
                        <label class="form-label fw-semibold">Vai trò</label>
                        <select id="addRole" class="form-select">
                            <option value="Student">Học viên</option>
                            <option value="Teacher">Giảng viên</option>
                            <option value="Admin">Quản trị viên</option>
                        </select>

                    </div>
                </form>
            </div>
            <div class="modal-footer border-0">
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Hủy</button>
                <button type="button" class="btn btn-primary" onclick="submitAddUser()">Thêm mới</button>
            </div>
        </div>
    </div>
</div>

<!-- Modal Sửa người dùng -->
<div class="modal fade" id="editUserModal" tabindex="-1">
    <div class="modal-dialog" style="margin-top:120px;">
        <div class="modal-content rounded-4">
            <div class="modal-header border-0">
                <h5 class="modal-title"><i class="bi-pencil-square me-2"></i>Sửa thông tin người dùng</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body">
                <form id="editUserForm">
                    <input type="hidden" id="editUserId">
                    <div class="mb-3">
                        <label class="form-label fw-semibold">Tên đăng nhập</label>
                        <input type="text" id="editUsername" class="form-control" readonly>
                    </div>
                    <div class="mb-3">
                        <label class="form-label fw-semibold">Họ và tên</label>
                        <input type="text" id="editFullname" class="form-control" required>
                    </div>
                    <div class="mb-3">
                        <label class="form-label fw-semibold">Email</label>
                        <input type="email" id="editEmail" class="form-control" required>
                    </div>
                    <div class="mb-3">
                        <label class="form-label fw-semibold">Vai trò</label>
                        <select id="editRole" class="form-select">
                            <option value="Student">Học viên</option>
                            <option value="Teacher">Giảng viên</option>
                            <option value="Admin">Quản trị viên</option>
                        </select>
                    </div>
                    <div class="mb-3">
                        <label class="form-label fw-semibold">Trạng thái</label>
                        <select id="editStatus" class="form-select">
                            <option value="Active">Hoạt động</option>
                            <option value="Locked">Khóa</option>
                        </select>
                    </div>
                </form>
            </div>
            <div class="modal-footer border-0">
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Hủy</button>
                <button type="button" class="btn btn-primary" onclick="submitEditUser()">Lưu thay đổi</button>
            </div>
        </div>
    </div>
</div>

<script>
    let currentUsers = [];
    let currentEditId = null;

    // Load users từ API
    function loadUsers() {
        const role = document.getElementById('filterRole').value;
        const status = document.getElementById('filterStatus').value;
        const search = document.getElementById('searchInput').value;

        let url = '/api/Api/users';
        let params = [];
        if (role) params.push(`role=${encodeURIComponent(role)}`);
        if (status) params.push(`status=${encodeURIComponent(status)}`);
        if (search) params.push(`search=${encodeURIComponent(search)}`);
        if (params.length > 0) url += '?' + params.join('&');

        fetch(url)
            .then(response => response.json())
            .then(data => {
                currentUsers = data;
                renderUserTable(data);
            })
            .catch(error => {
                console.error('Error:', error);
                document.getElementById('userTableBody').innerHTML = '<tr><td colspan="10" class="text-center text-danger py-4">Lỗi tải dữ liệu!</td></tr>';
            });
    }

    // Hiển thị bảng người dùng
    function renderUserTable(users) {
        const tbody = document.getElementById('userTableBody');
        if (!users || users.length === 0) {
            tbody.innerHTML = '<tr><td colspan="10" class="text-center py-4">Không có dữ liệu</td></tr>';
            return;
        }

        tbody.innerHTML = '';
        users.forEach(user => {
            const row = tbody.insertRow();
            const badgeClass = user.role === 'Admin' ? 'bg-danger' : (user.role === 'Teacher' ? 'bg-primary' : 'bg-info');
            const statusClass = user.status === 'Active' ? 'bg-success' : 'bg-secondary';

            row.innerHTML = `
                <td><input type="checkbox" class="userCheckbox" data-id="${user.id}" onchange="updateSelectedCount()"></td>
                <td>${user.id}</td>
                <td><img src="${user.avatar || '/Temp/images/avatar/default-avatar.png'}" class="rounded-circle" style="width: 35px; height: 35px; object-fit: cover;" onerror="this.src='/Temp/images/avatar/default-avatar.png'"></td>
                <td>${user.username}</td>
                <td>${user.fullname}</td>
                <td>${user.email}</td>
                <td><span class="badge ${badgeClass}">${user.role}</span></td>
                <td><span class="badge ${statusClass} status-badge" data-id="${user.id}" data-status="${user.status}">${user.status === 'Active' ? 'Hoạt động' : 'Khóa'}</span></td>
                <td>${user.createdAt || 'N/A'}</td>
                <td class="text-center">
                    <button class="btn btn-sm btn-outline-primary me-1" onclick='editUser(${JSON.stringify(user)})'>
                        <i class="bi-pencil"></i>
                    </button>
                    <button class="btn btn-sm btn-outline-warning me-1" onclick="toggleLockUser(${user.id}, '${user.username}', '${user.status}')">
                        <i class="bi-lock"></i>
                    </button>
                    <button class="btn btn-sm btn-outline-danger" onclick="deleteUser(${user.id}, '${user.username}')">
                        <i class="bi-trash"></i>
                    </button>
                </td>
            `;
        });

        updateSelectedCount();
    }

    // Reset bộ lọc
    function resetFilters() {
        document.getElementById('filterRole').value = '';
        document.getElementById('filterStatus').value = '';
        document.getElementById('searchInput').value = '';
        loadUsers();
    }

    // Thêm người dùng
    function submitAddUser() {
        const username = document.getElementById('addUsername').value;
        const password = document.getElementById('addPassword').value;
        const fullname = document.getElementById('addFullname').value;
        const email = document.getElementById('addEmail').value;
        const role = document.getElementById('addRole').value;

        if (!username || !password || !fullname || !email) {
            showToast('Vui lòng điền đầy đủ thông tin!', 'error');
            return;
        }

        fetch('/api/Api/user', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ username, password, fullname, email, role })
        })
        .then(response => response.json())
        .then(data => {
            if (data.success) {
                showToast(data.message, 'success');
                $('#addUserModal').modal('hide');
                document.getElementById('addUserForm').reset();
                loadUsers();
            } else {
                showToast(data.message || 'Thêm thất bại!', 'error');
            }
        })
        .catch(error => {
            console.error('Error:', error);
            showToast('Lỗi kết nối!', 'error');
        });
    }

    // Sửa người dùng
    function editUser(user) {
        currentEditId = user.id;
        document.getElementById('editUserId').value = user.id;
        document.getElementById('editUsername').value = user.username;
        document.getElementById('editFullname').value = user.fullname;
        document.getElementById('editEmail').value = user.email;
        document.getElementById('editRole').value = user.role;
        document.getElementById('editStatus').value = user.status;
        $('#editUserModal').modal('show');
    }

    function submitEditUser() {
        const id = document.getElementById('editUserId').value;
        const fullname = document.getElementById('editFullname').value;
        const email = document.getElementById('editEmail').value;
        const role = document.getElementById('editRole').value;
        const status = document.getElementById('editStatus').value;

        fetch(`/api/Api/user/${id}`, {
            method: 'PUT',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ fullname, email, role, status })
        })
        .then(response => response.json())
        .then(data => {
            if (data.success) {
                showToast(data.message, 'success');
                $('#editUserModal').modal('hide');
                loadUsers();
            } else {
                showToast(data.message || 'Cập nhật thất bại!', 'error');
            }
        })
        .catch(error => {
            console.error('Error:', error);
            showToast('Lỗi kết nối!', 'error');
        });
    }

    // Khóa/mở khóa người dùng
    function toggleLockUser(id, username, currentStatus) {
        const newStatus = currentStatus === 'Active' ? 'Locked' : 'Active';
        const action = newStatus === 'Locked' ? 'khóa' : 'mở khóa';

        if (confirm(`Bạn có chắc muốn ${action} người dùng "${username}"?`)) {
            fetch(`/api/Api/user/${id}/lock`, {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({ status: newStatus })
            })
            .then(response => response.json())
            .then(data => {
                if (data.success) {
                    showToast(data.message, 'success');
                    loadUsers();
                } else {
                    showToast(data.message || 'Thao tác thất bại!', 'error');
                }
            })
            .catch(error => {
                console.error('Error:', error);
                showToast('Lỗi kết nối!', 'error');
            });
        }
    }

    // Xóa người dùng
    function deleteUser(id, username) {
        if (confirm(`Bạn có chắc muốn xóa người dùng "${username}"? Hành động này không thể hoàn tác!`)) {
            fetch(`/api/Api/user/${id}`, {
                method: 'DELETE'
            })
            .then(response => response.json())
            .then(data => {
                if (data.success) {
                    showToast(data.message, 'success');
                    loadUsers();
                } else {
                    showToast(data.message || 'Xóa thất bại!', 'error');
                }
            })
            .catch(error => {
                console.error('Error:', error);
                showToast('Lỗi kết nối!', 'error');
            });
        }
    }

    // Bulk actions
    function toggleSelectAll() {
        const selectAll = document.getElementById('selectAll');
        const checkboxes = document.querySelectorAll('.userCheckbox');
        checkboxes.forEach(cb => cb.checked = selectAll.checked);
        updateSelectedCount();
    }

    function updateSelectedCount() {
        const checkboxes = document.querySelectorAll('.userCheckbox:checked');
        const count = checkboxes.length;
        document.getElementById('selectedCount').innerText = `Đã chọn ${count} người dùng`;

        const bulkLockBtn = document.getElementById('bulkLockBtn');
        const bulkDeleteBtn = document.getElementById('bulkDeleteBtn');

        if (count > 0) {
            bulkLockBtn.style.display = 'inline-block';
            bulkDeleteBtn.style.display = 'inline-block';
        } else {
            bulkLockBtn.style.display = 'none';
            bulkDeleteBtn.style.display = 'none';
        }
    }

    function bulkLock() {
        const checkboxes = document.querySelectorAll('.userCheckbox:checked');
        if (checkboxes.length === 0) return;

        if (confirm(`Bạn có chắc muốn khóa ${checkboxes.length} người dùng đã chọn?`)) {
            const promises = [];
            checkboxes.forEach(cb => {
                const id = cb.getAttribute('data-id');
                promises.push(fetch(`/api/Api/user/${id}/lock`, {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({ status: 'Locked' })
                }));
            });

            Promise.all(promises)
                .then(() => {
                    showToast(`Đã khóa ${checkboxes.length} người dùng!`, 'success');
                    loadUsers();
                })
                .catch(error => {
                    console.error('Error:', error);
                    showToast('Lỗi khi thực hiện!', 'error');
                });
        }
    }

    function bulkDelete() {
        const checkboxes = document.querySelectorAll('.userCheckbox:checked');
        if (checkboxes.length === 0) return;

        if (confirm(`Bạn có chắc muốn xóa ${checkboxes.length} người dùng? Hành động này không thể hoàn tác!`)) {
            const promises = [];
            checkboxes.forEach(cb => {
                const id = cb.getAttribute('data-id');
                promises.push(fetch(`/api/Api/user/${id}`, { method: 'DELETE' }));
            });

            Promise.all(promises)
                .then(() => {
                    showToast(`Đã xóa ${checkboxes.length} người dùng!`, 'success');
                    loadUsers();
                })
                .catch(error => {
                    console.error('Error:', error);
                    showToast('Lỗi khi thực hiện!', 'error');
                });
        }
    }

    // Toast notification
    function showToast(message, type = 'success') {
        const toast = document.createElement('div');
        toast.className = `toast align-items-center text-white bg-${type === 'success' ? 'success' : 'danger'} border-0 position-fixed bottom-0 end-0 m-3`;
        toast.setAttribute('role', 'alert');
        toast.setAttribute('aria-live', 'assertive');
        toast.setAttribute('aria-atomic', 'true');
        toast.style.zIndex = '9999';
        toast.innerHTML = `
            <div class="d-flex">
                <div class="toast-body">${message}</div>
                <button type="button" class="btn-close btn-close-white me-2 m-auto" data-bs-dismiss="toast"></button>
            </div>
        `;
        document.body.appendChild(toast);
        const bsToast = new bootstrap.Toast(toast, { delay: 3000 });
        bsToast.show();
        toast.addEventListener('hidden.bs.toast', () => toast.remove());
    }

    // Khởi tạo
    document.addEventListener('DOMContentLoaded', function() {
        loadUsers();
    });
</script>