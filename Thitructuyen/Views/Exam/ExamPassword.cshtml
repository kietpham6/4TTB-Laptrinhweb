@model Thitructuyen.Models.Exam
@{
    ViewData["Title"] = "Nhập mật khẩu đề thi";
}

<section class="section-padding pro-page-section">
    <div class="container">
        <div class="row justify-content-center">
            <div class="col-md-7 col-lg-5">
                <div class="card border-0 shadow-sm rounded-4">
                    <div class="card-body p-4 p-lg-5 text-center">
                        <div class="mb-3">
                            <span class="d-inline-flex align-items-center justify-content-center rounded-circle bg-primary bg-opacity-10 text-primary" style="width:72px;height:72px;font-size:34px;">
                                <i class="bi bi-shield-lock"></i>
                            </span>
                        </div>

                        <h3 class="fw-bold mb-2">Đề thi yêu cầu mật khẩu</h3>
                        <p class="text-muted mb-4">@Model.Title</p>

                        @if (TempData["ExamPasswordError"] != null)
                        {
                            <div class="alert alert-danger text-start">
                                <i class="bi bi-exclamation-triangle me-1"></i> @TempData["ExamPasswordError"]
                            </div>
                        }

                        <form asp-controller="Exam" asp-action="VerifyExamPassword" method="post" class="text-start">
                            @Html.AntiForgeryToken()
                            <input type="hidden" name="id" value="@Model.Id" />

                            <div class="mb-3">
                                <label class="form-label fw-semibold">Mật khẩu đề thi</label>
                                <input type="password" name="password" class="form-control form-control-lg" placeholder="Nhập mật khẩu" autocomplete="off" autofocus />
                            </div>

                            <button type="submit" class="btn btn-primary w-100 btn-lg">
                                <i class="bi bi-box-arrow-in-right me-1"></i> Vào làm bài
                            </button>
                        </form>

                        <a href="/Exam" class="btn btn-link mt-3 text-decoration-none">Quay lại danh sách bài thi</a>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>
