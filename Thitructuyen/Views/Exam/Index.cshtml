@model IEnumerable<Thitructuyen.Models.Exam>
@{
    ViewData["Title"] = "Danh sách bài thi";
    var now = DateTime.Now;
}

@if (TempData["ExamError"] != null)
{
    <div class="container mt-3">
        <div class="alert alert-warning text-center">@TempData["ExamError"]</div>
    </div>
}

<section class="services-section section-padding">
    <div class="container">
        <div class="row mb-4">
            <div class="col-12 text-center">
                <h2 class="mb-2">📚 Danh sách bài thi</h2>
                <p class="text-muted">Chọn bài thi bạn muốn tham gia</p>
            </div>
        </div>

        <div class="row g-4">
            @if (Model == null || !Model.Any())
            {
                <div class="col-12 text-center text-muted py-5">
                    <i class="bi-inbox" style="font-size:48px;"></i>
                    <p class="mt-3">Hiện chưa có bài thi nào.</p>
                </div>
            }
            else
            {
                foreach (var exam in Model)
                {
                    var isUpcoming = now < exam.StartTime;
                    var isClosed = now > exam.EndTime;
                    var isOpen = !isUpcoming && !isClosed;
                    var questionCount = exam.Questions?.Count ?? 0;

                    <div class="col-lg-4 col-md-6">
                        <div class="card border-0 shadow-sm rounded-4 h-100">
                            <div class="card-body p-4">
                                <div class="d-flex justify-content-between align-items-start mb-3">
                                    <span class="badge bg-primary px-3 py-2">@exam.Duration phút</span>
                                    @if (isOpen)
                                    {
                                        <span class="badge bg-success">Đang mở</span>
                                    }
                                    else if (isUpcoming)
                                    {
                                        <span class="badge bg-secondary">Sắp diễn ra</span>
                                    }
                                    else
                                    {
                                        <span class="badge bg-danger">Đã kết thúc</span>
                                    }
                                </div>
                                <h4 class="mb-2">@exam.Title</h4>
                                <p class="text-muted small mb-3">@exam.Description - @questionCount câu hỏi</p>
                                <p class="small text-muted mb-3">
                                    <i class="bi-calendar me-1"></i> Mở: @exam.StartTime.ToString("dd/MM/yyyy HH:mm")<br>
                                    <i class="bi-calendar-check me-1"></i> Hạn: @exam.EndTime.ToString("dd/MM/yyyy HH:mm")
                                </p>
                                <div class="d-flex justify-content-between align-items-center">
                                    <span class="text-success fw-bold">Miễn phí</span>
                                    @if (isOpen)
                                    {
                                        <a href="/Exam/TakeExam/@exam.Id" class="btn btn-primary">Làm bài ngay →</a>
                                    }
                                    else if (isUpcoming)
                                    {
                                        <button class="btn btn-secondary" disabled>Chưa mở</button>
                                    }
                                    else
                                    {
                                        <button class="btn btn-outline-secondary" disabled>Đã đóng</button>
                                    }
                                </div>
                            </div>
                        </div>
                    </div>
                }
            }
        </div>
    </div>
</section>
