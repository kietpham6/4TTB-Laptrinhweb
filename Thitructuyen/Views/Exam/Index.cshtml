@{
    ViewData["Title"] = "Danh sách bài thi";
}

<section class="services-section section-padding">
    <div class="container">
        <div class="row mb-4">
            <div class="col-12 text-center">
                <h2 class="mb-2">📚 Danh sách bài thi</h2>
                <p class="text-muted">Chọn bài thi bạn muốn tham gia</p>
            </div>
        </div>

        <div class="row g-4">
            <!-- Exam Card 1 -->
            <div class="col-lg-4 col-md-6">
                <div class="card border-0 shadow-sm rounded-4 h-100">
                    <div class="card-body p-4">
                        <div class="d-flex justify-content-between align-items-start mb-3">
                            <span class="badge bg-primary px-3 py-2">60 phút</span>
                            <span class="badge bg-success">Mới</span>
                        </div>
                        <h4 class="mb-2">Kiểm tra giữa kỳ</h4>
                        <p class="text-muted small mb-3">Lập trình Web - 50 câu hỏi</p>
                        <p class="small text-muted mb-3">
                            <i class="bi-calendar me-1"></i> Hạn: 30/03/2026<br>
                            <i class="bi-people me-1"></i> 45 người đã tham gia
                        </p>
                        <div class="d-flex justify-content-between align-items-center">
                            <span class="text-success fw-bold">Miễn phí</span>
                            <a href="/Exam/TakeExam/1" class="btn btn-primary">Làm bài ngay →</a>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Exam Card 2 -->
            <div class="col-lg-4 col-md-6">
                <div class="card border-0 shadow-sm rounded-4 h-100">
                    <div class="card-body p-4">
                        <div class="d-flex justify-content-between align-items-start mb-3">
                            <span class="badge bg-primary px-3 py-2">90 phút</span>
                            <span class="badge bg-warning">Sắp kết thúc</span>
                        </div>
                        <h4 class="mb-2">Ôn tập cuối kỳ</h4>
                        <p class="text-muted small mb-3">Cơ sở dữ liệu - 80 câu hỏi</p>
                        <p class="small text-muted mb-3">
                            <i class="bi-calendar me-1"></i> Hạn: 25/03/2026<br>
                            <i class="bi-people me-1"></i> 38 người đã tham gia
                        </p>
                        <div class="d-flex justify-content-between align-items-center">
                            <span class="text-success fw-bold">Miễn phí</span>
                            <a href="/Exam/TakeExam/2" class="btn btn-outline-primary">Làm bài ngay →</a>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Exam Card 3 -->
            <div class="col-lg-4 col-md-6">
                <div class="card border-0 shadow-sm rounded-4 h-100">
                    <div class="card-body p-4">
                        <div class="d-flex justify-content-between align-items-start mb-3">
                            <span class="badge bg-primary px-3 py-2">45 phút</span>
                            <span class="badge bg-secondary">Sắp diễn ra</span>
                        </div>
                        <h4 class="mb-2">Đánh giá năng lực</h4>
                        <p class="text-muted small mb-3">Tiếng Anh B1 - 40 câu hỏi</p>
                        <p class="small text-muted mb-3">
                            <i class="bi-calendar me-1"></i> Hạn: 05/04/2026<br>
                            <i class="bi-people me-1"></i> 52 người đã đăng ký
                        </p>
                        <div class="d-flex justify-content-between align-items-center">
                            <span class="text-success fw-bold">Miễn phí</span>
                            <button class="btn btn-secondary" disabled>Chưa mở</button>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>