@{
    ViewData["Title"] = "Kết quả thi";
    var score = ViewBag.Score ?? 0;
    var passed = ViewBag.Passed ?? false;
    var hasEssay = ViewBag.HasEssay ?? false;
}

<section class="section-padding">
    <div class="container">
        <div class="row justify-content-center">
            <div class="col-lg-7">
                <div class="card border-0 shadow-sm rounded-4 text-center p-4">
                    <div class="card-body">
                        @if (passed)
                        {
                            <i class="bi-trophy-fill" style="font-size:64px;color:#28a745;"></i>
                            <h3 class="mt-3 text-success">Chúc mừng! Bạn đã đỗ 🎉</h3>
                        }
                        else
                        {
                            <i class="bi-emoji-frown" style="font-size:64px;color:#dc3545;"></i>
                            <h3 class="mt-3 text-danger">Chưa đạt, cố gắng lần sau nhé!</h3>
                        }

                        <p class="text-muted mb-1">Đề thi: <strong>@ViewBag.ExamTitle</strong></p>

                        <div class="my-4">
                            <span class="display-3 fw-bold @(passed ? "text-success" : "text-danger")">@score</span>
                            <span class="fs-4 text-muted">/ 10</span>
                        </div>

                        <p class="text-muted">
                            Số điểm trắc nghiệm: @ViewBag.RawScore / @ViewBag.TotalPoints
                            (@ViewBag.Percentage%)
                        </p>

                        @if (hasEssay)
                        {
                            <div class="alert alert-warning mt-3">
                                ⏳ Bài có câu tự luận — điểm hiển thị là điểm tạm tính. Vui lòng chờ giáo viên chấm để có điểm cuối cùng.
                            </div>
                        }

                        <div class="mt-4">
                            <a href="/Student/History" class="btn btn-primary me-2">📜 Xem lịch sử thi</a>
                            <a href="/Exam" class="btn btn-outline-secondary">📚 Về danh sách bài thi</a>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>
