@model Exam
@{
    ViewData["Title"] = "Bài thi: " + Model?.Title;
    Layout = null;
}

<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <title>@ViewData["Title"]</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.1.3/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.8.1/font/bootstrap-icons.css">
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Poppins:wght@400;500;600;700&display=swap" rel="stylesheet">
    <style>
        :root{
            --bx-brand:#4f83d1; --bx-brand-600:#3b6cb8; --bx-brand-700:#2d5396;
            --bx-brand-50:#eef5fc; --bx-ink:#14233b; --bx-line:#e6edf6;
            --bx-success:#16a34a; --bx-warning:#ea9f0c; --bx-danger:#e23b4e;
            --bx-ease:cubic-bezier(.4,0,.2,1);
        }
        *{ -webkit-font-smoothing:antialiased; }
        body{
            background:#eaf1fa;
            background-image:radial-gradient(1200px 400px at 50% -120px, #dbe8f8 0%, rgba(234,241,250,0) 70%);
            font-family:'Poppins',sans-serif; color:var(--bx-ink);
        }
        .exam-container{ max-width:1180px; margin:0 auto; padding:22px 18px 60px; }

        .exam-header{
            background:linear-gradient(120deg,var(--bx-brand) 0%,var(--bx-brand-600) 70%,var(--bx-brand-700) 130%);
            color:#fff; border-radius:18px; padding:18px 26px; margin-bottom:22px;
            position:sticky; top:14px; z-index:100;
            box-shadow:0 14px 32px rgba(45,83,150,.32);
        }
        .exam-header h3{ font-weight:700; letter-spacing:-.01em; }
        .exam-header small{ opacity:.85; }
        .timer-box{
            background:rgba(255,255,255,.18); border:1px solid rgba(255,255,255,.28);
            border-radius:12px; padding:8px 18px; font-size:22px; font-weight:700;
            font-variant-numeric:tabular-nums; letter-spacing:.02em;
            -webkit-backdrop-filter:blur(6px); backdrop-filter:blur(6px);
        }
        .timer-box.danger{ background:rgba(226,59,78,.92); border-color:transparent; animation:pulse 1s infinite; }
        @@keyframes pulse{ 0%,100%{ opacity:1; } 50%{ opacity:.6; } }

        .question-card{
            background:#fff; border:1px solid var(--bx-line); border-radius:16px;
            padding:22px 24px; margin-bottom:16px;
            box-shadow:0 2px 6px rgba(20,42,77,.05);
            transition:box-shadow .25s var(--bx-ease), transform .25s var(--bx-ease), border-color .25s var(--bx-ease);
        }
        .question-card:hover{ box-shadow:0 12px 30px rgba(20,42,77,.1); transform:translateY(-2px); }
        .question-card.current{ border-color:var(--bx-brand); box-shadow:0 0 0 3px rgba(79,131,209,.15),0 10px 26px rgba(20,42,77,.1); }
        .question-card h5{ font-weight:600; line-height:1.5; }

        .question-number{
            background:linear-gradient(135deg,var(--bx-brand),var(--bx-brand-600));
            color:#fff; min-width:36px; width:36px; height:36px; border-radius:11px;
            display:inline-flex; align-items:center; justify-content:center;
            margin-right:12px; font-weight:700; box-shadow:0 4px 10px rgba(79,131,209,.35);
        }

        .option{
            display:flex; align-items:center; gap:12px;
            margin:10px 0; padding:13px 16px;
            border:1.5px solid var(--bx-line); border-radius:12px;
            cursor:pointer; transition:all .18s var(--bx-ease); background:#fff;
        }
        .option:hover{ border-color:#b9d6f1; background:var(--bx-brand-50); }
        .option input{ width:18px; height:18px; margin:0; accent-color:var(--bx-brand); cursor:pointer; }
        .option label{ margin:0; cursor:pointer; flex:1; font-weight:500; }
        .option.selected{
            border-color:var(--bx-brand); background:var(--bx-brand-50);
            box-shadow:inset 0 0 0 1px var(--bx-brand);
        }
        .option.selected label{ color:var(--bx-brand-700); font-weight:600; }

        .nav-sidebar{
            position:sticky; top:110px; background:#fff;
            border:1px solid var(--bx-line); border-radius:16px; padding:18px;
            box-shadow:0 4px 16px rgba(20,42,77,.07);
        }
        .nav-sidebar h6{ font-weight:700; color:var(--bx-ink); }
        .question-nav{
            display:inline-flex; align-items:center; justify-content:center;
            width:40px; height:40px; margin:4px; border-radius:10px;
            cursor:pointer; font-weight:700; font-size:.9rem;
            border:1.5px solid var(--bx-line); transition:all .18s var(--bx-ease);
        }
        .question-nav:hover{ transform:translateY(-2px); }
        .question-nav.answered{ background:var(--bx-success); color:#fff; border-color:transparent; }
        .question-nav.current{ background:var(--bx-brand); color:#fff; border-color:transparent; box-shadow:0 0 0 3px rgba(79,131,209,.25); }
        .question-nav.pending{ background:#f1f5fa; color:#7a89a3; }

        .progress-wrap{ height:8px; background:var(--bx-brand-50); border-radius:999px; overflow:hidden; }
        .progress-wrap > span{ display:block; height:100%; width:0; border-radius:999px;
            background:linear-gradient(90deg,var(--bx-brand),var(--bx-brand-600)); transition:width .3s var(--bx-ease); }

        .submit-btn{
            background:linear-gradient(135deg,var(--bx-brand),var(--bx-brand-600));
            border:none; padding:13px 30px; font-size:17px; font-weight:700;
            width:100%; border-radius:12px; color:#fff;
            box-shadow:0 8px 20px rgba(79,131,209,.32); transition:all .2s var(--bx-ease);
        }
        .submit-btn:hover{ transform:translateY(-2px); box-shadow:0 12px 26px rgba(45,83,150,.4); color:#fff; }

        .legend-badge{ display:inline-flex; align-items:center; gap:6px; font-size:.8rem; }
        .legend-dot{ width:14px; height:14px; border-radius:5px; display:inline-block; }

        #warningModal .modal-content{ border:none; border-radius:18px; overflow:hidden; }
        #warningModal .modal-header{ border:none; }
        .warning-count{ color:var(--bx-danger); font-weight:700; font-size:24px; }
        hr{ border-color:var(--bx-line); opacity:1; }
        .exit-btn{ border-radius:12px; font-weight:600; }
    </style>
</head>
<body>
    <div class="exam-container">
        <div class="exam-header">
            <div class="row align-items-center">
                <div class="col-md-8">
                    <h3 class="mb-0">📝 @Model?.Title</h3>
                    <small>Môn: @Model?.Description</small>
                </div>
                <div class="col-md-4 text-end">
                    <div class="timer-box d-inline-block">
                        ⏱️ <span id="timer">00:00</span>
                    </div>
                </div>
            </div>
        </div>

        <div class="row">
            <!-- Main Content -->
            <div class="col-lg-9">
                <form id="examForm" method="post" action="/Exam/SubmitExam">
                    <input type="hidden" name="examId" value="@Model.Id" />
                    <div id="questions-container">
                        @if (Model?.Questions != null)
                        {
                            int index = 1;
                            foreach (var q in Model.Questions)
                            {
                                <div class="question-card" data-question-id="@q.Id" data-question-index="@index">
                                    <div class="d-flex align-items-center mb-3">
                                        <span class="question-number">@index</span>
                                        <h5 class="mb-0">@q.Text</h5>
                                    </div>
                                    <div class="options">
                                        <div class="option">
                                            <input type="radio" name="answers[@q.Id]" value="A" id="q@(q.Id)_A">
                                            <label for="q@(q.Id)_A">A. @q.OptionA</label>
                                        </div>
                                        <div class="option">
                                            <input type="radio" name="answers[@q.Id]" value="B" id="q@(q.Id)_B">
                                            <label for="q@(q.Id)_B">B. @q.OptionB</label>
                                        </div>
                                        <div class="option">
                                            <input type="radio" name="answers[@q.Id]" value="C" id="q@(q.Id)_C">
                                            <label for="q@(q.Id)_C">C. @q.OptionC</label>
                                        </div>
                                        <div class="option">
                                            <input type="radio" name="answers[@q.Id]" value="D" id="q@(q.Id)_D">
                                            <label for="q@(q.Id)_D">D. @q.OptionD</label>
                                        </div>
                                    </div>
                                </div>
                                index++;
                            }
                        }
                    </div>

                    <button type="submit" class="btn btn-primary submit-btn mt-3" onclick="return confirmSubmit()">
                        📤 Nộp bài thi
                    </button>
                </form>
            </div>

            <!-- Sidebar Navigation -->
            <div class="col-lg-3">
                <div class="nav-sidebar">
                    <h6 class="mb-2"><i class="bi-grid-3x3-gap-fill me-1"></i> Điều hướng câu hỏi</h6>
                    <div class="d-flex justify-content-between small text-muted mb-1">
                        <span>Tiến độ</span>
                        <span><strong id="answeredCount">0</strong>/<span id="totalCount">0</span> câu</span>
                    </div>
                    <div class="progress-wrap mb-3"><span id="progressBar"></span></div>
                    <div id="question-nav-container"></div>
                    <hr>
                    <div class="d-flex flex-wrap gap-3">
                        <span class="legend-badge"><span class="legend-dot" style="background:#16a34a;"></span> Đã làm</span>
                        <span class="legend-badge"><span class="legend-dot" style="background:#4f83d1;"></span> Hiện tại</span>
                        <span class="legend-badge"><span class="legend-dot" style="background:#e2e8f0;"></span> Chưa làm</span>
                    </div>
                    <hr>
                    <button class="btn btn-outline-danger w-100 exit-btn" onclick="window.location.href='/Exam'">
                        <i class="bi-box-arrow-left me-1"></i> Thoát bài thi
                    </button>
                </div>
            </div>
        </div>
    </div>

    <!-- Warning Modal -->
    <div class="modal fade" id="warningModal" tabindex="-1">
        <div class="modal-dialog modal-dialog-centered">
            <div class="modal-content">
                <div class="modal-header bg-warning">
                    <h5 class="modal-title">⚠️ Cảnh báo gian lận</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                </div>
                <div class="modal-body text-center">
                    <i class="bi-exclamation-triangle-fill" style="font-size: 48px; color: #ffc107;"></i>
                    <p class="mt-3">Bạn đã <span id="warningCount" class="warning-count">0</span> lần vi phạm!</p>
                    <p>Sau 3 lần vi phạm, bài thi sẽ tự động bị hủy!</p>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-warning" data-bs-dismiss="modal">Tiếp tục thi</button>
                </div>
            </div>
        </div>
    </div>

    <script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.1.3/dist/js/bootstrap.bundle.min.js"></script>
    <script>
        const totalTime = @Model?.Duration * 60;
        let timeLeft = totalTime;
        let warningCount = 0;
        let tabSwitchCount = 0;

        function recordViolation(type) {
            warningCount++;
            $('#warningModal').modal('show');
            const countEl = document.getElementById('warningCount');
            if (countEl) countEl.textContent = warningCount;
            $.post('/Exam/LogViolation', {
                examId: @Model?.Id,
                violationType: type,
                timestamp: new Date().toISOString()
            });
            if (warningCount >= 3) {
                alert('Bạn đã vi phạm quá 3 lần! Hệ thống sẽ tự động nộp bài.');
                submitExamSafely();
            }
        }

        // Timer
        function updateTimer() {
            let minutes = Math.floor(timeLeft / 60);
            let seconds = timeLeft % 60;
            const t = document.getElementById('timer');
            t.innerHTML =
                (minutes < 10 ? '0' + minutes : minutes) + ':' +
                (seconds < 10 ? '0' + seconds : seconds);

            // Đổi sang trạng thái cảnh báo khi còn dưới 60 giây
            const box = t.closest('.timer-box');
            if (box) box.classList.toggle('danger', timeLeft <= 60);

            if (timeLeft <= 0) {
                clearInterval(timerInterval);
                alert('Hết giờ! Bài thi sẽ được tự động nộp.');
                submitExamSafely();
            }
            timeLeft--;
        }

        const timerInterval = setInterval(updateTimer, 1000);

        // Auto save every 30 seconds
        setInterval(function() {
            saveAnswers();
        }, 30000);

        function saveAnswers() {
            const formData = $('#examForm').serialize();
            $.ajax({
                url: '/Exam/AutoSave',
                type: 'POST',
                data: formData,
                success: function(response) {
                    console.log('Auto saved at ' + new Date().toLocaleTimeString());
                }
            });
        }

        // Question navigation
        function buildNavigation() {
            const questions = document.querySelectorAll('.question-card');
            const container = document.getElementById('question-nav-container');
            container.innerHTML = '';

            questions.forEach((q, index) => {
                const questionId = q.dataset.questionId;
                const hasAnswer = document.querySelector(`input[name="answers[${questionId}]"]:checked`) !== null;
                const isCurrent = q.classList.contains('current');

                const navItem = document.createElement('div');
                navItem.className = `question-nav ${hasAnswer ? 'answered' : 'pending'} ${isCurrent ? 'current' : ''}`;
                navItem.textContent = index + 1;
                navItem.onclick = () => scrollToQuestion(index);
                container.appendChild(navItem);
            });
        }

        // Tô sáng đáp án đang được chọn
        function refreshOptionStates() {
            document.querySelectorAll('.option').forEach(opt => {
                const input = opt.querySelector('input[type="radio"]');
                opt.classList.toggle('selected', !!(input && input.checked));
            });
        }

        // Cập nhật thanh tiến độ
        function updateProgress() {
            const cards = document.querySelectorAll('.question-card');
            let answered = 0;
            cards.forEach(q => {
                if (document.querySelector(`input[name="answers[${q.dataset.questionId}]"]:checked`)) answered++;
            });
            document.getElementById('answeredCount').textContent = answered;
            document.getElementById('totalCount').textContent = cards.length;
            document.getElementById('progressBar').style.width =
                (cards.length ? (answered / cards.length * 100) : 0) + '%';
        }

        function onAnswerChange() {
            refreshOptionStates();
            buildNavigation();
            updateProgress();
        }

        function scrollToQuestion(index) {
            const questions = document.querySelectorAll('.question-card');
            questions[index].scrollIntoView({ behavior: 'smooth', block: 'center' });
        }

        // Bấm vào bất kỳ đâu trong dòng đáp án để chọn
        document.querySelectorAll('.option').forEach(opt => {
            opt.addEventListener('click', e => {
                if (e.target.tagName !== 'INPUT') {
                    const input = opt.querySelector('input[type="radio"]');
                    if (input && !input.checked) {
                        input.checked = true;
                        input.dispatchEvent(new Event('change', { bubbles: true }));
                    }
                }
            });
        });

        // Tự đánh dấu câu hỏi đang xem là "hiện tại"
        const ioCards = document.querySelectorAll('.question-card');
        if ('IntersectionObserver' in window && ioCards.length) {
            const io = new IntersectionObserver((entries) => {
                entries.forEach(en => {
                    if (en.isIntersecting) {
                        ioCards.forEach(c => c.classList.remove('current'));
                        en.target.classList.add('current');
                        buildNavigation();
                    }
                });
            }, { rootMargin: '-45% 0px -45% 0px', threshold: 0 });
            ioCards.forEach(c => io.observe(c));
        }

        // Update navigation when answers change
        document.querySelectorAll('input[type="radio"]').forEach(radio => {
            radio.addEventListener('change', onAnswerChange);
        });

        // Anti-cheat: Detect tab switching
        document.addEventListener('visibilitychange', function() {
            if (document.hidden) {
                tabSwitchCount++;
                recordViolation('Tab Switch / Rời khỏi màn hình thi');
            }
        });

        // Anti-cheat: Disable right click
        document.addEventListener('contextmenu', function(e) {
            e.preventDefault();
            return false;
        });

        // Anti-cheat: Disable copy
        document.addEventListener('copy', function(e) {
            e.preventDefault();
            return false;
        });

        // Anti-cheat: Disable cut
        document.addEventListener('cut', function(e) {
            e.preventDefault();
            return false;
        });

        // Anti-cheat: Disable paste
        document.addEventListener('paste', function(e) {
            e.preventDefault();
            return false;
        });


        // Anti-cheat nâng cao: chặn phím tắt thường dùng để mở DevTools/lưu/in/tải lại.
        document.addEventListener('keydown', function(e) {
            const key = (e.key || '').toLowerCase();
            const blocked = e.key === 'F12' ||
                (e.ctrlKey && e.shiftKey && ['i','j','c'].includes(key)) ||
                (e.ctrlKey && ['s','p','u','r'].includes(key));
            if (blocked) {
                e.preventDefault();
                recordViolation('Blocked shortcut: ' + e.key);
                return false;
            }
        });

        window.addEventListener('blur', function() {
            recordViolation('Window Blur / Mất focus khỏi bài thi');
        });

        // Anti-cheat: Detect fullscreen exit
        document.addEventListener('fullscreenchange', function() {
            if (!document.fullscreenElement) {
                recordViolation('Fullscreen Exit / Thoát toàn màn hình');
            }
        });

        // Request fullscreen on start
        function requestFullscreen() {
            const elem = document.documentElement;
            if (elem.requestFullscreen) {
                elem.requestFullscreen();
            }
        }
        requestFullscreen();

        function submitExamSafely() {
            const form = document.getElementById('examForm');
            if (!form) return;
            if (form.dataset.submitting === '1') return;
            form.dataset.submitting = '1';
            if (form.requestSubmit) form.requestSubmit();
            else form.submit();
        }

        function confirmSubmit() {
            let unanswered = 0;
            document.querySelectorAll('.question-card').forEach(q => {
                const questionId = q.dataset.questionId;
                if (!document.querySelector(`input[name="answers[${questionId}]"]:checked`)) {
                    unanswered++;
                }
            });

            if (unanswered > 0) {
                return confirm(`Bạn còn ${unanswered} câu chưa trả lời. Bạn có chắc muốn nộp bài không?`);
            }
            return confirm('Bạn có chắc chắn muốn nộp bài thi?');
        }

        // Initialize navigation
        buildNavigation();
        refreshOptionStates();
        updateProgress();
    </script>
</body>
</html>