                                </div>
                                <div class="ms-4">
                                    <h4 class="text-white mb-1">Nguyễn Anh Đức</h4>
                                    <p class="text-white-50 mb-1 small">⚡ Tiến bộ - 30 bài thi</p>
                                    <div class="reviews-icons">
                                        <i class="bi-star-fill text-warning"></i>
                                        <i class="bi-star-fill text-warning"></i>
                                        <i class="bi-star-fill text-warning"></i>
                                        <i class="bi-star-fill text-warning"></i>
                                        <i class="bi-star text-white-50"></i>
                                    </div>
                                </div>
                            </div>
                            <p class="mt-3 mb-0 text-white-50 fst-italic small">
                                <i class="bi-quote me-2"></i>"Tôi đã cải thiện điểm số đáng kể sau khi sử dụng hệ thống để luyện tập hàng ngày."
                            </p>
                        </div>
                    </div>
                </div>
            </div>
        </section>

        <style>
            .featured-block:hover {
                transform: translateY(-5px);
                background: rgba(255,255,255,0.15) !important;
                transition: all 0.3s ease;
            }
        </style>


        <section class="partners-section">
            <div class="container">
                <div class="row justify-content-center align-items-center">

                    <div class="col-lg-12 col-12">
                        <h4 class="partners-section-title bg-white shadow-lg">Đối tác giáo dục</h4>
                    </div>

                    <div class="col-lg-2 col-md-4 col-6">
                        <img src="/Temp/images/partners/toprak-leasing.svg" class="partners-image img-fluid">
                    </div>

                    <div class="col-lg-2 col-md-4 col-6">
                        <img src="/Temp/images/partners/glorix.svg" class="partners-image img-fluid">
                    </div>

                    <div class="col-lg-2 col-md-4 col-6">
                        <img src="/Temp/images/partners/woocommerce.svg" class="partners-image img-fluid">
                    </div>

                    <div class="col-lg-2 col-md-4 col-6">
                        <img src="/Temp/images/partners/rolf-leasing.svg" class="partners-image img-fluid">
                    </div>

                    <div class="col-lg-2 col-md-4 col-6">
                        <img src="/Temp/images/partners/unilabs.svg" class="partners-image img-fluid">
                    </div>

                </div>
            </div>
        </section>

        <!-- ========== THÊM SECTION CALL TO ACTION VÀO CUỐI TRANG ========== -->
        <section class="py-5" style="background: linear-gradient(135deg, #4f83d1 0%, #3b6cb8 100%);">
            <div class="container text-center">
                <h2 class="text-white mb-4">🚀 Sẵn sàng để thử thách bản thân?</h2>
                <p class="text-white mb-4">Hàng ngàn câu hỏi, đa dạng môn học đang chờ bạn</p>

                <div class="d-flex justify-content-center gap-3 flex-wrap">
                    @if (User.Identity.IsAuthenticated)
                    {
                        <a class="btn btn-light px-4 py-2 rounded-pill fw-bold" asp-controller="Exam" asp-action="Index">
                            📝 Bắt đầu thi ngay
                        </a>
                    }
                    else
                    {
                        <a class="btn btn-light px-4 py-2 rounded-pill fw-bold" asp-controller="Account" asp-action="Login">
                            🔐 Đăng nhập để thi
                        </a>
                        <a class="btn btn-warning px-4 py-2 rounded-pill fw-bold" asp-controller="Account" asp-action="Register">
                            📝 Đăng ký miễn phí
                        </a>
                    }
                </div>
            </div>
        </section>

    </main>


</body>
</html>