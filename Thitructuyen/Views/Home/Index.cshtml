                        <div class="mt-4 d-flex justify-content-center gap-3">
                            @if (User.Identity.IsAuthenticated)
                            {
                                var role = User.FindFirst(ClaimTypes.Role)?.Value;
                                if (role == "Admin")
                                {
                                    <a href="/Admin/Dashboard" class="btn btn-danger px-4 py-2 rounded-pill">
                                        🔧 Vào trang quản trị
                                    </a>
                                }
                                else if (role == "Teacher")
                                {
                                    <a href="/Teacher/Dashboard" class="btn btn-primary px-4 py-2 rounded-pill">
                                        📚 Vào trang giảng viên
                                    </a>
                                }
                                else if (role == "Student")
                                {
                                    <a href="/Student/Dashboard" class="btn btn-success px-4 py-2 rounded-pill">
                                        📖 Vào trang học viên
                                    </a>
                                }
                            }
                            else
                            {
                                <a class="btn btn-outline-light px-4 py-2 rounded-pill" asp-controller="Account" asp-action="Login">
                                    🔐 Đăng nhập
                                </a>
                                <a class="btn btn-warning px-4 py-2 rounded-pill" asp-controller="Account" asp-action="Register">
                                    📝 Đăng ký miễn phí
                                </a>
                            }
