<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <meta name="description" content="">
    <meta name="author" content="">
    <title>@ViewData["Title"] - Thi Trực Tuyến</title>
    <link rel="icon" type="image/x-icon" href="/favicon.ico">

    <!-- CSS FILES -->
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Poppins:ital,wght@0,400;0,500;0,700;1,400&display=swap" rel="stylesheet">
    <link href="/Temp/css/bootstrap.min.css" rel="stylesheet">
    <link href="/Temp/css/bootstrap-icons.css" rel="stylesheet">
    <link href="/Temp/css/tooplate-clean-work.css" rel="stylesheet">
    <!-- Lớp tinh chỉnh chuyên nghiệp (nạp cuối để ghi đè) -->
    <link href="~/css/site-pro.css" rel="stylesheet" asp-append-version="true">

    <style>
        /* Khu vực nội dung chính giữ chiều cao tối thiểu để footer không "trồi" lên */
        main { min-height: 72vh; }
        .auth-section, .login-section, .register-section { margin-top: 24px; }

        @@media (max-width: 991.98px) {
            .navbar-nav.ms-auto { margin-top: 12px; }
            .navbar .navbar-nav .nav-link { margin: 2px 0 !important; }
            .navbar .nav-item.ms-3, .navbar .nav-item.ms-2 { margin-left: 0 !important; }
        }
    </style>
</head>
<body>

   
    <!-- NAVBAR - GIỮ NGUYÊN template cũ của bạn -->
    <nav class="navbar navbar-expand-lg">
        <div class="container">
            <a class="navbar-brand" asp-controller="Home" asp-action="Index">
                <img src="/images/main-logo.png" class="logo img-fluid" alt="Thi Trực Tuyến">
                <span class="ms-2">Thi Trực Tuyến</span>
            </a>

            <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarNav" aria-controls="navbarNav" aria-expanded="false" aria-label="Toggle navigation">
                <span class="navbar-toggler-icon"></span>
            </button>

            <div class="collapse navbar-collapse" id="navbarNav">
                <ul class="navbar-nav ms-auto">
                    <!-- Menu Home - GIỮ NGUYÊN -->
                    <li class="nav-item">
                        <a class="nav-link active" asp-controller="Home" asp-action="Index">Trang chủ</a>
                    </li>

                    <!-- Menu Bài Thi - THÊM MỚI -->
                    <li class="nav-item">
                        <a class="nav-link" asp-controller="Exam" asp-action="Index">Bài Thi</a>
                    </li>

                    @if (User.Identity.IsAuthenticated)
                    {
                        var role = User.FindFirst(ClaimTypes.Role)?.Value;

                        @if (role == "Admin")
                        {
                            <!-- Admin Dropdown -->
                            <li class="nav-item dropdown">
                                <a class="nav-link dropdown-toggle" href="#" role="button" data-bs-toggle="dropdown" aria-expanded="false">Admin</a>
                                <ul class="dropdown-menu dropdown-menu-light">
                                    <li><a class="dropdown-item" asp-controller="Admin" asp-action="Dashboard">📊 Dashboard Admin</a></li>
                                    <li><a class="dropdown-item" asp-controller="Admin" asp-action="Users">👥 Quản lý người dùng</a></li>
                                    <li><a class="dropdown-item" asp-controller="Admin" asp-action="Subjects">📚 Quản lý môn học</a></li>
                                    <li><a class="dropdown-item" asp-controller="Admin" asp-action="QuestionBank">📖 Ngân hàng câu hỏi</a></li>
                                    <li><a class="dropdown-item" asp-controller="Admin" asp-action="Exams">📝 Quản lý kỳ thi</a></li>
                                    <li><a class="dropdown-item" asp-controller="Admin" asp-action="Statistics">📊 Thống kê</a></li>
                                    <li><a class="dropdown-item" asp-controller="Admin" asp-action="ActivityLogs">🧾 Audit Log</a></li>
                                    <li><a class="dropdown-item" asp-controller="Admin" asp-action="Settings">⚙️ Cấu hình</a></li>
                                </ul>
                            </li>
                        }
                        else if (role == "Teacher")
                        {
                            <!-- Teacher Dropdown -->
                            <li class="nav-item dropdown">
                                <a class="nav-link dropdown-toggle" href="#" role="button" data-bs-toggle="dropdown" aria-expanded="false">Giảng viên</a>
                                <ul class="dropdown-menu dropdown-menu-light">
                                    <li><a class="dropdown-item" asp-controller="Teacher" asp-action="QuestionBank">📖 Ngân hàng câu hỏi</a></li>
                                    <li><a class="dropdown-item" asp-controller="Teacher" asp-action="Exams">📝 Quản lý đề thi</a></li>
                                    <li><a class="dropdown-item" asp-controller="Teacher" asp-action="CreateExam">➕ Tạo đề thi</a></li>
                                    <li><a class="dropdown-item" asp-controller="Teacher" asp-action="Grading">✏️ Chấm bài</a></li>
                                    <li><a class="dropdown-item" asp-controller="Teacher" asp-action="Statistics">📊 Thống kê giảng dạy</a></li>
                                    <li><a class="dropdown-item" asp-controller="Teacher" asp-action="Proctoring">👁️ Giám sát Anti-cheat</a></li>
                                </ul>
                            </li>
                        }
                        else if (role == "Student")
                        {
                            <!-- Student Dropdown -->
                            <li class="nav-item dropdown">
                                <a class="nav-link dropdown-toggle" href="#" role="button" data-bs-toggle="dropdown" aria-expanded="false">Học viên</a>
                                <ul class="dropdown-menu dropdown-menu-light">
                                    <li><a class="dropdown-item" asp-controller="Student" asp-action="Dashboard">🎓 Dashboard của tôi</a></li>
                                    <li><a class="dropdown-item" asp-controller="Exam" asp-action="Index">📝 Bài thi của tôi</a></li>
                                    <li><a class="dropdown-item" asp-controller="Student" asp-action="History">📜 Lịch sử thi</a></li>
                                    <li><a class="dropdown-item" asp-controller="Student" asp-action="Ranking">🏆 Xếp hạng</a></li>
                                    <li><a class="dropdown-item" asp-controller="Student" asp-action="Statistics">📊 Thống kê cá nhân</a></li>
                                </ul>
                            </li>
                        }
                    }

                    <!-- Nút Get started / Đăng nhập / User menu -->
                    @if (User.Identity.IsAuthenticated)
                    {
                        var fullName = User.FindFirst("FullName")?.Value ?? User.Identity.Name;
                        var avatar = User.FindFirst("Avatar")?.Value ?? "";

                        <li class="nav-item dropdown ms-3">
                            <a class="nav-link dropdown-toggle d-flex align-items-center" href="#" role="button" data-bs-toggle="dropdown" aria-expanded="false">
                                <img src="@(string.IsNullOrEmpty(avatar) ? "https://ui-avatars.com/api/?background=4f83d1&color=fff&size=35&rounded=true&name=" + fullName : avatar)"
                                     class="user-avatar me-2"
                                     onerror="this.src='https://ui-avatars.com/api/?background=4f83d1&color=fff&size=35&rounded=true&name=User'">
                                <span>@fullName</span>
                            </a>
                            <ul class="dropdown-menu dropdown-menu-light dropdown-menu-end">
                                <li><a class="dropdown-item" asp-controller="Account" asp-action="Profile">👤 Hồ sơ</a></li>
                                <li><a class="dropdown-item" asp-controller="Account" asp-action="ChangePassword">🔑 Đổi mật khẩu</a></li>
                                <li><hr class="dropdown-divider"></li>
                                <li><a class="dropdown-item text-danger" asp-controller="Account" asp-action="Logout">🚪 Đăng xuất</a></li>
                            </ul>
                        </li>
                    }
                    else
                    {
                        <li class="nav-item ms-3">
                            <a class="nav-link custom-btn custom-border-btn custom-btn-bg-white btn" asp-controller="Account" asp-action="Login">Đăng nhập</a>
                        </li>
                        <li class="nav-item ms-2">
                            <a class="nav-link custom-btn btn btn-primary text-white" asp-controller="Account" asp-action="Register">Đăng ký</a>
                        </li>
                    }
                </ul>
            </div>
        </div>
    </nav>

    <!-- MAIN CONTENT -->
    @if (User.Identity != null && User.Identity.IsAuthenticated)
    {
        <div class="app-shell">
            @await Html.PartialAsync("_AppSidebar")
            <main role="main" class="app-main">
                @RenderBody()
            </main>
        </div>
    }
    else
    {
        <div class="container">
            <main role="main" class="pb-3">
                @RenderBody()
            </main>
        </div>
    }

    <!-- FOOTER -->
    @if (!(User.Identity != null && User.Identity.IsAuthenticated))
    {
    <footer class="site-footer">
        <div class="container">
            <div class="row">
                <div class="col-lg-12 col-12 d-flex align-items-center mb-4 pb-2 flex-wrap">
                    <div class="d-flex align-items-center">
                        <img src="/images/main-logo.png" class="logo img-fluid" alt="Thi Trực Tuyến">
                        <span class="text-white fw-bold ms-3" style="font-size:1.25rem;">Thi Trực Tuyến</span>
                    </div>
                    <ul class="footer-menu d-flex flex-wrap ms-lg-5 ms-0 mt-3 mt-lg-0">
                        <li class="footer-menu-item"><a asp-controller="Home" asp-action="Index" class="footer-menu-link">Trang chủ</a></li>
                        <li class="footer-menu-item"><a asp-controller="Exam" asp-action="Index" class="footer-menu-link">Bài thi</a></li>
                        <li class="footer-menu-item"><a asp-controller="Student" asp-action="Ranking" class="footer-menu-link">Xếp hạng</a></li>
                        <li class="footer-menu-item"><a href="#" class="footer-menu-link">Hướng dẫn</a></li>
                        <li class="footer-menu-item"><a href="#" class="footer-menu-link">Liên hệ</a></li>
                    </ul>
                </div>

                <div class="col-lg-5 col-12 mb-4 mb-lg-0">
                    <h5 class="site-footer-title mb-3">Danh mục thi</h5>
                    <ul class="footer-menu">
                        <li class="footer-menu-item">
                            <a href="#" class="footer-menu-link">
                                <i class="bi-chevron-double-right footer-menu-link-icon me-2"></i>
                                Khoa học tự nhiên
                            </a>
                        </li>
                        <li class="footer-menu-item">
                            <a href="#" class="footer-menu-link">
                                <i class="bi-chevron-double-right footer-menu-link-icon me-2"></i>
                                Khoa học xã hội
                            </a>
                        </li>
                        <li class="footer-menu-item">
                            <a href="#" class="footer-menu-link">
                                <i class="bi-chevron-double-right footer-menu-link-icon me-2"></i>
                                Công nghệ thông tin
                            </a>
                        </li>
                        <li class="footer-menu-item">
                            <a href="#" class="footer-menu-link">
                                <i class="bi-chevron-double-right footer-menu-link-icon me-2"></i>
                                Ngoại ngữ
                            </a>
                        </li>
                        <li class="footer-menu-item">
                            <a href="#" class="footer-menu-link">
                                <i class="bi-chevron-double-right footer-menu-link-icon me-2"></i>
                                Luyện thi tổng hợp
                            </a>
                        </li>
                    </ul>
                </div>

                <div class="col-lg-4 col-md-6 col-12 mb-4 mb-lg-0 mb-md-0">
                    <h5 class="site-footer-title mb-3">Liên hệ</h5>
                    <p class="text-white d-flex mt-3 mb-2">
                        <i class="bi-geo-alt-fill me-2"></i>
                        268 Lý Thường Kiệt, Quận 10, TP. Hồ Chí Minh
                    </p>
                    <p class="text-white d-flex mb-2">
                        <i class="bi-telephone-fill me-2"></i>
                        <a href="tel:0123456789" class="site-footer-link">0123 456 789</a>
                    </p>
                    <p class="text-white d-flex">
                        <i class="bi-envelope-fill me-2"></i>
                        <a href="mailto:support@thitructuyen.vn" class="site-footer-link">support@thitructuyen.vn</a>
                    </p>
                    <ul class="social-icon mt-4">
                        <li class="social-icon-item">
                            <a href="#" class="social-icon-link button button--skoll">
                                <span></span>
                                <span class="bi-facebook"></span>
                            </a>
                        </li>
                        <li class="social-icon-item">
                            <a href="#" class="social-icon-link button button--skoll">
                                <span></span>
                                <span class="bi-youtube"></span>
                            </a>
                        </li>
                        <li class="social-icon-item">
                            <a href="#" class="social-icon-link button button--skoll">
                                <span></span>
                                <span class="bi-envelope"></span>
                            </a>
                        </li>
                    </ul>
                </div>

                <div class="col-lg-3 col-md-6 col-6 mt-3 mt-lg-0 mt-md-0">
                    <div class="featured-block">
                        <h5 class="text-white mb-3">Giờ hỗ trợ</h5>
                        <strong class="d-block text-white mb-1">Thứ 2 - Thứ 6</strong>
                        <p class="text-white mb-3">8:00 - 17:30</p>
                        <strong class="d-block text-white mb-1">Thứ 7</strong>
                        <p class="text-white mb-0">8:00 - 11:30</p>
                    </div>
                </div>
            </div>
        </div>

        <div class="site-footer-bottom">
            <div class="container">
                <div class="row">
                    <div class="col-lg-6 col-12">
                        <p class="copyright-text mb-0">© @DateTime.Now.Year Thi Trực Tuyến. Bảo lưu mọi quyền.</p>
                    </div>
                    <div class="col-lg-6 col-12 text-end">
                        <p class="copyright-text mb-0">Hệ thống thi trực tuyến chuyên nghiệp.</p>
                    </div>
                </div>
            </div>
        </div>
    </footer>

    }

    <!-- JAVASCRIPT FILES -->
    <script src="/Temp/js/jquery.min.js"></script>
    <script src="/Temp/js/bootstrap.min.js"></script>
    <script src="/Temp/js/jquery.backstretch.min.js"></script>
    <script src="/Temp/js/counter.js"></script>
    <script src="/Temp/js/countdown.js"></script>
    <script src="/Temp/js/init.js"></script>
    <script src="/Temp/js/modernizr.js"></script>
    <script src="/Temp/js/animated-headline.js"></script>
    <script src="/Temp/js/custom.js"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>