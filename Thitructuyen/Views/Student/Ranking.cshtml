@{
    ViewData["Title"] = "Xếp hạng";
}

<div class="pro-page-title">
    <div>
        <h2>🏆 Bảng xếp hạng học viên</h2>
        <p>Xếp hạng lấy trực tiếp từ database dựa trên các lượt thi đã có điểm.</p>
    </div>
</div>

<div class="chart-card mb-4">
    <div class="row g-3 align-items-end">
        <div class="col-md-5">
            <label class="form-label">Môn học</label>
            <select class="form-select" id="rankingSubject">
                <option value="all">Tất cả môn học</option>
            </select>
        </div>
        <div class="col-md-4">
            <label class="form-label">Thời gian</label>
            <select class="form-select" id="rankingPeriod">
                <option value="all">Tất cả thời gian</option>
                <option value="month">Tháng này</option>
                <option value="quarter">Quý này</option>
                <option value="year">Năm nay</option>
            </select>
        </div>
        <div class="col-md-3 d-grid">
            <button class="btn btn-outline-secondary" type="button" onclick="resetFilters()"><i class="bi-arrow-repeat me-1"></i>Reset</button>
        </div>
    </div>
</div>

<div class="row g-4 mb-4 text-center" id="top3Container">
    <div class="col-12">
        <div class="chart-card text-center text-muted py-5">Đang tải dữ liệu xếp hạng...</div>
    </div>
</div>

<div class="chart-card">
    <div class="d-flex justify-content-between align-items-center mb-3 flex-wrap gap-2">
        <h5 class="mb-0">📊 Bảng xếp hạng chi tiết</h5>
        <span class="badge bg-primary">Dữ liệu thật</span>
    </div>
    <div class="table-responsive">
        <table class="table table-hover align-middle mb-0">
            <thead>
                <tr>
                    <th>Hạng</th>
                    <th>Học viên</th>
                    <th>Số bài thi</th>
                    <th>Điểm TB</th>
                    <th>Cao nhất</th>
                    <th>Thấp nhất</th>
                    <th>Vi phạm</th>
                </tr>
            </thead>
            <tbody id="rankingTableBody">
                <tr><td colspan="7" class="text-center text-muted py-4">Đang tải...</td></tr>
            </tbody>
        </table>
    </div>
    <div class="pt-3 d-flex justify-content-between align-items-center flex-wrap gap-2">
        <span class="text-muted" id="resultCount">📊 Hiển thị 0 học viên</span>
        <span class="text-muted small">Nguồn: ExamAttempts + Users + Exams trong database</span>
    </div>
</div>

@section Scripts {
<script>
const safe = v => `${v ?? ''}`.replace(/[&<>'"]/g, m => ({'&':'&amp;','<':'&lt;','>':'&gt;',"'":'&#39;','"':'&quot;'}[m]));
const avatarFallback = name => `https://ui-avatars.com/api/?background=4f83d1&color=fff&size=80&rounded=true&name=${encodeURIComponent(name || 'User')}`;

async function loadSubjects(){
    try{
        const res = await fetch('/api/Api/subjects');
        if(!res.ok) return;
        const subjects = await res.json();
        const select = document.getElementById('rankingSubject');
        select.innerHTML = '<option value="all">Tất cả môn học</option>' + (subjects || []).map(s => `<option value="${safe(s.name)}">${safe(s.name)}</option>`).join('');
    }catch{ }
}

function medal(rank){ return rank === 1 ? '🥇' : rank === 2 ? '🥈' : rank === 3 ? '🥉' : '🏅'; }
function cardClass(rank){ return rank === 1 ? 'bg-warning bg-opacity-10 shadow-lg' : rank === 2 ? 'bg-secondary bg-opacity-10' : 'bg-info bg-opacity-10'; }

function renderTop3(data){
    const top = (data || []).slice(0, 3);
    const wrap = document.getElementById('top3Container');
    if(top.length === 0){
        wrap.innerHTML = '<div class="col-12"><div class="chart-card text-center text-muted py-5">Chưa có dữ liệu xếp hạng. Học viên cần nộp bài và có điểm trước.</div></div>';
        return;
    }
    wrap.innerHTML = top.map(x => `
        <div class="col-md-4">
            <div class="card border-0 rounded-4 ${cardClass(x.rank)} h-100">
                <div class="card-body p-4">
                    <div class="display-3 mb-2">${medal(x.rank)}</div>
                    <img src="${safe(x.avatar || avatarFallback(x.fullName || x.name))}" onerror="this.src='${avatarFallback(x.fullName || x.name)}'" class="rounded-circle mb-3" style="width:80px;height:80px;object-fit:cover;">
                    <h4 class="mb-1">${safe(x.fullName || x.name)}</h4>
                    <p class="text-muted mb-2">Điểm TB: <strong>${x.avgScore ?? 0}/10</strong></p>
                    <span class="badge ${x.rank === 1 ? 'bg-warning text-dark' : x.rank === 2 ? 'bg-secondary' : 'bg-info'}">Hạng ${x.rank}</span>
                </div>
            </div>
        </div>`).join('');
}

function renderTable(data){
    const body = document.getElementById('rankingTableBody');
    if(!data || data.length === 0){
        body.innerHTML = '<tr><td colspan="7" class="text-center text-muted py-4">Chưa có dữ liệu xếp hạng</td></tr>';
        document.getElementById('resultCount').textContent = '📊 Hiển thị 0 học viên';
        return;
    }
    body.innerHTML = data.map(x => `
        <tr class="${x.rank === 1 ? 'table-warning' : x.rank === 2 ? 'table-light' : x.rank === 3 ? 'table-info' : ''}">
            <td><span class="badge ${x.rank <= 3 ? 'bg-warning text-dark' : 'bg-primary'}">#${x.rank}</span></td>
            <td><div class="d-flex align-items-center gap-2"><img src="${safe(x.avatar || avatarFallback(x.fullName || x.name))}" onerror="this.src='${avatarFallback(x.fullName || x.name)}'" style="width:38px;height:38px;border-radius:50%;object-fit:cover"><b>${safe(x.fullName || x.name)}</b></div></td>
            <td>${x.attempts ?? x.exams ?? 0}</td>
            <td><b class="text-success">${x.avgScore ?? 0}</b>/10</td>
            <td>${x.bestScore ?? x.highest ?? 0}/10</td>
            <td>${x.lowest ?? 0}/10</td>
            <td>${x.violations ?? 0}</td>
        </tr>`).join('');
    document.getElementById('resultCount').textContent = `📊 Hiển thị ${data.length} học viên`;
}

async function loadRanking(){
    const subject = document.getElementById('rankingSubject').value || 'all';
    const period = document.getElementById('rankingPeriod').value || 'all';
    const url = `/api/dashboard/leaderboard?subject=${encodeURIComponent(subject)}&period=${encodeURIComponent(period)}`;
    try{
        const res = await fetch(url);
        if(!res.ok) throw new Error('Không tải được dữ liệu xếp hạng');
        const data = await res.json();
        renderTop3(data);
        renderTable(data);
    }catch(err){
        document.getElementById('top3Container').innerHTML = '<div class="col-12"><div class="chart-card text-center text-danger py-5">' + safe(err.message) + '</div></div>';
        document.getElementById('rankingTableBody').innerHTML = '<tr><td colspan="7" class="text-center text-danger py-4">' + safe(err.message) + '</td></tr>';
    }
}

function resetFilters(){
    document.getElementById('rankingSubject').value = 'all';
    document.getElementById('rankingPeriod').value = 'all';
    loadRanking();
}

document.getElementById('rankingSubject').addEventListener('change', loadRanking);
document.getElementById('rankingPeriod').addEventListener('change', loadRanking);
loadSubjects().then(loadRanking);
</script>
}
