    function filterRanking() {
        var subject = document.getElementById('rankingSubject').value;
        var period = document.getElementById('rankingPeriod').value;
        var filteredData = [];

        // Chọn dữ liệu theo môn học
        if (subject !== 'all' && rankingBySubject[subject]) {
            filteredData = JSON.parse(JSON.stringify(rankingBySubject[subject]));
        } else if (subject !== 'all' && !rankingBySubject[subject]) {
            filteredData = [];
        } else {
            filteredData = JSON.parse(JSON.stringify(rankingData));
        }

        // Lọc theo thời gian (mô phỏng)
        if (period === 'month') {
            filteredData = filteredData.map(function(item) {
                var newItem = JSON.parse(JSON.stringify(item));
                newItem.avgScore = (parseFloat(newItem.avgScore) * 0.95).toFixed(1);
                return newItem;
            });
        } else if (period === 'quarter') {
            filteredData = filteredData.map(function(item) {
                var newItem = JSON.parse(JSON.stringify(item));
                newItem.avgScore = (parseFloat(newItem.avgScore) * 0.98).toFixed(1);
                return newItem;
            });
        } else if (period === 'year') {
            filteredData = filteredData.map(function(item) {
                var newItem = JSON.parse(JSON.stringify(item));
                newItem.avgScore = (parseFloat(newItem.avgScore) * 0.9).toFixed(1);
                return newItem;
            });
        }

        // Sắp xếp theo điểm
        filteredData.sort(function(a, b) {
            return parseFloat(b.avgScore) - parseFloat(a.avgScore);
        });

        // Cập nhật lại hạng
        for (var i = 0; i < filteredData.length; i++) {
            filteredData[i].rank = i + 1;
        }

        renderRankingTable(filteredData);
        updateTop3(filteredData);
        updateYourRank(filteredData, subject, period);
    }

    function renderRankingTable(data) {
        var tbody = document.getElementById('rankingTableBody');
        if (!data || data.length === 0) {
            tbody.innerHTML = '<tr><td colspan="6" class="text-center py-4">📭 Không có dữ liệu xếp hạng!</td></tr>';
            document.getElementById('resultCount').innerHTML = '📊 Hiển thị 0 của 0 học viên';
            return;
        }

        tbody.innerHTML = '';
        for (var i = 0; i < data.length; i++) {
            var item = data[i];
            var rowClass = '';
            if (item.rank === 1) rowClass = 'table-warning';
            else if (item.rank === 2) rowClass = 'table-secondary';
            else if (item.rank === 3) rowClass = 'table-info';
            else if (item.name === 'Bạn') rowClass = 'table-active';

            var trendIcon = '';
            if (item.trend === 'up') trendIcon = '<i class="bi-arrow-up-short text-success"></i> ' + (item.trendValue || '+');
            else if (item.trend === 'down') trendIcon = '<i class="bi-arrow-down-short text-danger"></i> ' + (item.trendValue || '-');
            else trendIcon = '<i class="bi-dash text-secondary"></i> ' + (item.trendValue || '0');

            var avatarUrl = item.avatar || 'https://ui-avatars.com/api/?background=6c757d&color=fff&size=30&rounded=true&name=' + encodeURIComponent(item.name);

            var row = '<tr class="' + rowClass + '">' +
                '<td class="fw-bold">' + item.rank + '</td>' +
                '<td><img src="' + avatarUrl + '" class="rounded-circle me-2" style="width: 30px; height: 30px;"> ' + item.name + '</td>' +
                '<td>' + item.exams + '</td>' +
                '<td class="fw-bold ' + (parseFloat(item.avgScore) >= 8 ? 'text-success' : (parseFloat(item.avgScore) >= 5 ? 'text-warning' : 'text-danger')) + '">' + item.avgScore + '</td>' +
                '<td>' + item.highest + '</td>' +
                '<td>' + trendIcon + '</td>' +
                '</tr>';
            tbody.innerHTML += row;
        }

        document.getElementById('resultCount').innerHTML = '📊 Hiển thị ' + data.length + ' của ' + (data.length === rankingData.length ? '15' : data.length) + ' học viên';
    }

    function updateTop3(data) {
        var top3Container = document.getElementById('top3Container');
        if (!data || data.length < 3) return;

        var html = '';
        var medals = ['🥈', '🥇', '🥉'];
        var badgeClasses = ['bg-secondary', 'bg-warning text-dark', 'bg-info'];

        for (var i = 0; i < 3; i++) {
            var item = data[i];
            var medalIndex = i === 0 ? 1 : (i === 1 ? 0 : 2);
            html += '<div class="col-md-4">' +
                '<div class="card border-0 shadow-sm rounded-4 ' + (i === 0 ? 'bg-warning bg-opacity-10' : (i === 1 ? 'bg-secondary bg-opacity-10' : 'bg-info bg-opacity-10')) + '">' +
                '<div class="card-body p-4 text-center">' +
                '<div class="display-1 mb-3">' + medals[medalIndex] + '</div>' +
                '<img src="' + (item.avatar || 'https://ui-avatars.com/api/?background=6c757d&color=fff&size=80&rounded=true&name=' + encodeURIComponent(item.name)) + '" class="rounded-circle mb-3" style="width: 80px; height: 80px; object-fit: cover;">' +
                '<h4>' + item.name + '</h4>' +
                '<p class="text-muted">Điểm TB: <strong>' + item.avgScore + '</strong></p>' +
                '<span class="badge ' + badgeClasses[medalIndex] + '">Hạng ' + (i + 1) + '</span>' +
                '</div></div></div>';
        }
        top3Container.innerHTML = html;
    }

    function updateYourRank(data, subject, period) {
        var yourRankInfo = document.getElementById('yourRankInfo');
        var yourData = null;
        for (var i = 0; i < data.length; i++) {
            if (data[i].name === 'Bạn') {
                yourData = data[i];
                break;
            }
        }

        if (yourData) {
            yourRankInfo.innerHTML = '<span class="badge bg-primary">📌 Vị trí của bạn: #' + yourData.rank + ' - Điểm TB: ' + yourData.avgScore + '</span>';
        } else {
            yourRankInfo.innerHTML = '<span class="badge bg-secondary">📌 Bạn chưa có trong bảng xếp hạng này</span>';
        }
    }

    function resetFilters() {
        document.getElementById('rankingSubject').value = 'all';
        document.getElementById('rankingPeriod').value = 'all';
        filterRanking();
    }

    // Khởi tạo bảng khi trang load
    document.addEventListener('DOMContentLoaded', function() {
        filterRanking();
    });
</script>