@{
    ViewData["Title"] = "Xếp hạng";
}

<section class="services-section section-padding">
    <div class="container">
        <div class="row mb-4">
            <div class="col-12">
                <h2>🏆 Bảng xếp hạng học viên</h2>
                <p class="text-muted">Xem thành tích và so sánh với các học viên khác</p>
            </div>
        </div>

        <!-- Bộ lọc -->
        <div class="card border-0 shadow-sm rounded-4 mb-4">
            <div class="card-body p-4">
                <div class="row g-3">
                    <div class="col-md-4">
                        <select class="form-select" id="rankingSubject" onchange="filterRanking()">
                            <option value="all">Tất cả môn học</option>
                            <option value="Lập trình Web">Lập trình Web</option>
                            <option value="Cơ sở dữ liệu">Cơ sở dữ liệu</option>
                            <option value="Tiếng Anh">Tiếng Anh</option>
                            <option value="Toán cao cấp">Toán cao cấp</option>
                        </select>
                    </div>
                    <div class="col-md-4">
                        <select class="form-select" id="rankingPeriod" onchange="filterRanking()">
                            <option value="all">Tất cả thời gian</option>
                            <option value="month">Tháng này</option>
                            <option value="quarter">Quý này</option>
                            <option value="year">Năm nay</option>
                        </select>
                    </div>
                    <div class="col-md-4">
                        <button class="btn btn-outline-secondary w-100" onclick="resetFilters()">
                            <i class="bi-arrow-repeat me-1"></i>Reset
                        </button>
                    </div>
                </div>
            </div>
        </div>

        <!-- Top 3 -->
        <div class="row g-4 mb-5 text-center" id="top3Container">
            <div class="col-md-4">
                <div class="card border-0 shadow-sm rounded-4 bg-secondary bg-opacity-10">
                    <div class="card-body p-4">
                        <div class="display-1 mb-3">🥈</div>
                        <img src="https://ui-avatars.com/api/?background=6c757d&color=fff&size=80&rounded=true&name=Trần+Thị+B" class="rounded-circle mb-3" style="width: 80px; height: 80px; object-fit: cover;">
                        <h4>Trần Thị B</h4>
                        <p class="text-muted">Điểm TB: <strong>8.9</strong></p>
                        <span class="badge bg-secondary">Hạng 2</span>
                    </div>
                </div>
            </div>
            <div class="col-md-4">
                <div class="card border-0 shadow-lg rounded-4 bg-warning bg-opacity-10">
                    <div class="card-body p-4">
                        <div class="display-1 mb-3">🥇</div>
                        <img src="https://ui-avatars.com/api/?background=ffc107&color=fff&size=80&rounded=true&name=Nguyễn+Văn+A" class="rounded-circle mb-3" style="width: 80px; height: 80px; object-fit: cover;">
                        <h4>Nguyễn Văn A</h4>
                        <p class="text-muted">Điểm TB: <strong>9.5</strong></p>
                        <span class="badge bg-warning text-dark">Hạng 1</span>
                    </div>
                </div>
            </div>
            <div class="col-md-4">
                <div class="card border-0 shadow-sm rounded-4 bg-info bg-opacity-10">
                    <div class="card-body p-4">
                        <div class="display-1 mb-3">🥉</div>
                        <img src="https://ui-avatars.com/api/?background=0dcaf0&color=fff&size=80&rounded=true&name=Lê+Văn+C" class="rounded-circle mb-3" style="width: 80px; height: 80px; object-fit: cover;">
                        <h4>Lê Văn C</h4>
                        <p class="text-muted">Điểm TB: <strong>8.5</strong></p>
                        <span class="badge bg-info">Hạng 3</span>
                    </div>
                </div>
            </div>
        </div>

        <!-- Danh sách xếp hạng chi tiết -->
        <div class="card border-0 shadow-sm rounded-4">
            <div class="card-header bg-white border-0 pt-4 px-4">
                <h5 class="mb-0">📊 Bảng xếp hạng chi tiết</h5>
            </div>
            <div class="card-body p-0">
                <div class="table-responsive">
                    <table class="table table-hover mb-0" id="rankingTable">
                        <thead class="bg-light">
                            <tr>
                                <th>Hạng</th>
                                <th>Học viên</th>
                                <th>Số bài thi</th>
                                <th>Điểm TB</th>
                                <th>Cao nhất</th>
                                <th>Xu hướng</th>
                            </tr>
                        </thead>
                        <tbody id="rankingTableBody"></tbody>
                    </table>
                </div>
            </div>
            <div class="card-footer bg-white border-0 pt-3 pb-3">
                <div class="d-flex justify-content-between align-items-center">
                    <span class="text-muted" id="resultCount">📊 Hiển thị 0 của 0 học viên</span>
                    <div id="yourRankInfo"></div>
                </div>
            </div>
        </div>
    </div>
</section>

