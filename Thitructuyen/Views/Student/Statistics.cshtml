@{
    ViewData["Title"] = "Thống kê cá nhân";
}
<div class="pro-page-title">
    <div>
        <h2>📊 Thống kê cá nhân</h2>
        <p>Dữ liệu lấy trực tiếp từ lịch sử làm bài, điểm số và vi phạm Anti-cheat của tài khoản hiện tại.</p>
    </div>
    <a class="btn btn-outline-primary" asp-controller="Student" asp-action="History"><i class="bi-clock-history me-1"></i> Lịch sử thi</a>
</div>

<div class="row g-4 mb-4">
    <div class="col-md-6 col-xl-3"><div class="metric-card"><div class="metric-icon"><i class="bi-file-earmark-text"></i></div><div class="metric-value" data-k="totalAttempts">0</div><div class="metric-label">Tổng lượt thi</div></div></div>
    <div class="col-md-6 col-xl-3"><div class="metric-card"><div class="metric-icon"><i class="bi-star"></i></div><div class="metric-value" data-k="avgScore">0</div><div class="metric-label">Điểm trung bình</div></div></div>
    <div class="col-md-6 col-xl-3"><div class="metric-card"><div class="metric-icon"><i class="bi-trophy"></i></div><div class="metric-value" data-k="bestScore">0</div><div class="metric-label">Điểm cao nhất</div></div></div>
    <div class="col-md-6 col-xl-3"><div class="metric-card"><div class="metric-icon"><i class="bi-check-circle"></i></div><div class="metric-value"><span data-k="passRate">0</span>%</div><div class="metric-label">Tỷ lệ đạt</div></div></div>
</div>

<div class="row g-4 mb-4">
    <div class="col-xl-8">
        <div class="chart-card">
            <div class="d-flex justify-content-between align-items-center mb-3">
                <h5 class="mb-0">📈 Điểm theo thời gian</h5>
                <span class="badge bg-primary">Dữ liệu thật</span>
            </div>
            <canvas id="scoreTrendChart" height="125"></canvas>
        </div>
    </div>
    <div class="col-xl-4">
        <div class="chart-card">
            <h5 class="mb-3">🍩 Điểm TB theo môn</h5>
            <canvas id="subjectChart" height="180"></canvas>
        </div>
    </div>
</div>

<div class="row g-4">
    <div class="col-xl-7">
        <div class="chart-card">
            <h5 class="mb-3">📚 Thống kê chi tiết theo môn học</h5>
            <div class="table-responsive">
                <table class="table table-hover table-pro align-middle">
                    <thead><tr><th>Môn học</th><th>Lượt thi</th><th>Điểm TB</th><th>Cao nhất</th><th>Thấp nhất</th><th>Tỷ lệ đạt</th></tr></thead>
                    <tbody id="subjectRows"><tr><td colspan="6" class="text-center text-muted py-4">Đang tải...</td></tr></tbody>
                </table>
            </div>
        </div>
    </div>
    <div class="col-xl-5">
        <div class="chart-card mb-4">
            <h5 class="mb-3 text-success">✅ Môn đang tốt</h5>
            <div id="strengths" class="vstack gap-2"></div>
        </div>
        <div class="chart-card">
            <h5 class="mb-3 text-danger">⚠️ Môn cần cải thiện</h5>
            <div id="weaknesses" class="vstack gap-2"></div>
        </div>
    </div>
</div>

@section Scripts {
<script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
<script>
let scoreTrendChart, subjectChart;
const safe = v => `${v ?? ''}`.replace(/[&<>'"]/g, m => ({'&':'&amp;','<':'&lt;','>':'&gt;',"'":'&#39;','"':'&quot;'}[m]));
function metric(k, value){ document.querySelectorAll(`[data-k="${k}"]`).forEach(el => el.textContent = value ?? 0); }
function listBox(items, empty){
    if(!items || items.length === 0) return `<div class="text-muted">${empty}</div>`;
    return items.map(x => `<div class="border rounded-3 p-3 d-flex justify-content-between align-items-center"><div><b>${safe(x.subject)}</b><br><small class="text-muted">${x.attempts} lượt thi</small></div><span class="badge bg-primary">${x.avgScore}/10</span></div>`).join('');
}
fetch('/api/dashboard/student-statistics')
    .then(r => { if(!r.ok) throw new Error('Không có quyền hoặc API lỗi'); return r.json(); })
    .then(data => {
        ['totalAttempts','avgScore','bestScore','passRate'].forEach(k => metric(k, data[k]));
        const trend = data.trend || [];
        const bySubject = data.bySubject || [];
        if(window.Chart){
            scoreTrendChart = new Chart(document.getElementById('scoreTrendChart'), {
                type:'line',
                data:{ labels: trend.map(x=>x.label), datasets:[{ label:'Điểm', data: trend.map(x=>x.score), tension:.35, fill:true }] },
                options:{ responsive:true, scales:{ y:{ min:0, max:10 } } }
            });
            subjectChart = new Chart(document.getElementById('subjectChart'), {
                type:'doughnut',
                data:{ labels: bySubject.map(x=>x.subject), datasets:[{ data: bySubject.map(x=>x.avgScore) }] },
                options:{ responsive:true }
            });
        }
        document.getElementById('subjectRows').innerHTML = bySubject.length
            ? bySubject.map(x => `<tr><td><b>${safe(x.subject)}</b></td><td>${x.attempts}</td><td><b>${x.avgScore}</b>/10</td><td>${x.highest}</td><td>${x.lowest}</td><td>${x.passRate}%</td></tr>`).join('')
            : '<tr><td colspan="6" class="text-center text-muted py-4">Chưa có dữ liệu thi</td></tr>';
        document.getElementById('strengths').innerHTML = listBox(data.strengths, 'Chưa đủ dữ liệu để xác định điểm mạnh');
        document.getElementById('weaknesses').innerHTML = listBox(data.weaknesses, 'Chưa đủ dữ liệu để xác định điểm cần cải thiện');
    })
    .catch(err => {
        document.getElementById('subjectRows').innerHTML = `<tr><td colspan="6" class="text-center text-danger py-4">${safe(err.message)}</td></tr>`;
    });
</script>
}
