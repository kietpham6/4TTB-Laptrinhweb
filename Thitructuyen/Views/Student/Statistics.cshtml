@{
    ViewData["Title"] = "Thống kê cá nhân";
    var fullName = User.FindFirst("FullName")?.Value ?? User.Identity.Name;
}

<section class="services-section section-padding">
    <div class="container">
        <div class="row mb-4">
            <div class="col-12">
                <h2>📊 Thống kê cá nhân</h2>
                <p class="text-muted">Xem tiến độ học tập và kết quả của bạn</p>
            </div>
        </div>

        <!-- Tổng quan -->
        <div class="row g-4 mb-5">
            <div class="col-md-3">
                <div class="card border-0 shadow-sm rounded-4 bg-primary text-white">
                    <div class="card-body p-4">
                        <div class="d-flex justify-content-between align-items-center">
                            <div>
                                <h6 class="text-white-50 mb-1">Tổng số bài thi</h6>
                                <h2 class="text-white mb-0" id="totalExams">12</h2>
                            </div>
                            <i class="bi-file-text-fill fs-1 text-white-50"></i>
                        </div>
                    </div>
                </div>
            </div>
            <div class="col-md-3">
                <div class="card border-0 shadow-sm rounded-4 bg-success text-white">
                    <div class="card-body p-4">
                        <div class="d-flex justify-content-between align-items-center">
                            <div>
                                <h6 class="text-white-50 mb-1">Điểm trung bình</h6>
                                <h2 class="text-white mb-0" id="avgScore">8.5</h2>
                            </div>
                            <i class="bi-star-fill fs-1 text-white-50"></i>
                        </div>
                    </div>
                </div>
            </div>
            <div class="col-md-3">
                <div class="card border-0 shadow-sm rounded-4 bg-warning text-white">
                    <div class="card-body p-4">
                        <div class="d-flex justify-content-between align-items-center">
                            <div>
                                <h6 class="text-white-50 mb-1">Điểm cao nhất</h6>
                                <h2 class="text-white mb-0" id="highestScore">10</h2>
                            </div>
                            <i class="bi-trophy-fill fs-1 text-white-50"></i>
                        </div>
                    </div>
                </div>
            </div>
            <div class="col-md-3">
                <div class="card border-0 shadow-sm rounded-4 bg-info text-white">
                    <div class="card-body p-4">
                        <div class="d-flex justify-content-between align-items-center">
                            <div>
                                <h6 class="text-white-50 mb-1">Xếp hạng</h6>
                                <h2 class="text-white mb-0" id="ranking">#15</h2>
                            </div>
                            <i class="bi-bar-chart-fill fs-1 text-white-50"></i>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <!-- Biểu đồ tiến độ -->
        <div class="row g-4 mb-5">
            <div class="col-md-8">
                <div class="card border-0 shadow-sm rounded-4">
                    <div class="card-header bg-white border-0 pt-4 px-4">
                        <h5 class="mb-0">📈 Biểu đồ điểm theo thời gian</h5>
                    </div>
                    <div class="card-body p-4">
                        <canvas id="scoreTrendChart" height="250"></canvas>
                    </div>
                </div>
            </div>
            <div class="col-md-4">
                <div class="card border-0 shadow-sm rounded-4">
                    <div class="card-header bg-white border-0 pt-4 px-4">
                        <h5 class="mb-0">🍩 Phân bố điểm theo môn</h5>
                    </div>
                    <div class="card-body p-4">
                        <canvas id="subjectChart" height="200"></canvas>
                    </div>
                </div>
            </div>
        </div>

        <!-- Thống kê theo môn học -->
        <div class="card border-0 shadow-sm rounded-4 mb-5">
            <div class="card-header bg-white border-0 pt-4 px-4">
                <h5 class="mb-0">📚 Thống kê chi tiết theo môn học</h5>
            </div>
            <div class="card-body p-0">
                <div class="table-responsive">
                    <table class="table table-hover mb-0">
                        <thead class="bg-light">
                            <tr>
                                <th class="ps-4">Môn học</th>
                                <th>Số bài thi</th>
                                <th>Điểm TB</th>
                                <th>Cao nhất</th>
                                <th>Thấp nhất</th>
                                <th>Xu hướng</th>
                            </tr>
                        </thead>
                        <tbody>
                            <tr>
                                <td class="ps-4 fw-bold">Lập trình Web</td>
                                <td>4</td>
                                <td><span class="fw-bold text-success">8.8</span></td>
                                <td>10</td>
                                <td>7.5</td>
                                <td><i class="bi-arrow-up-short text-success"></i> +0.5</td>
                            </tr>
                            <tr>
                                <td class="ps-4 fw-bold">Cơ sở dữ liệu</td>
                                <td>3</td>
                                <td><span class="fw-bold text-warning">7.5</span></td>
                                <td>8.5</td>
                                <td>6.5</td>
                                <td><i class="bi-arrow-down-short text-danger"></i> -0.3</td>
                            </tr>
                            <tr>
                                <td class="ps-4 fw-bold">Tiếng Anh</td>
                                <td>3</td>
                                <td><span class="fw-bold text-success">8.2</span></td>
                                <td>9.0</td>
                                <td>7.0</td>
                                <td><i class="bi-arrow-up-short text-success"></i> +0.8</td>
                            </tr>
                            <tr>
                                <td class="ps-4 fw-bold">Toán cao cấp</td>
                                <td>2</td>
                                <td><span class="fw-bold text-warning">7.0</span></td>
                                <td>7.5</td>
                                <td>6.5</td>
                                <td><i class="bi-arrow-down-short text-danger"></i> -0.5</td>
                            </tr>
                        </tbody>
                    </table>
                </div>
            </div>
        </div>

        <!-- Điểm mạnh - Điểm yếu -->
        <div class="row g-4">
            <div class="col-md-6">
                <div class="card border-0 shadow-sm rounded-4">
                    <div class="card-header bg-white border-0 pt-4 px-4">
                        <h5 class="mb-0 text-success">✅ Điểm mạnh</h5>
                    </div>
                    <div class="card-body p-4">
                        <ul class="list-group list-group-flush">
                            <li class="list-group-item d-flex justify-content-between align-items-center border-0 px-0">
                                <span><i class="bi-check-circle-fill text-success me-2"></i> Lập trình Web</span>
                                <span class="badge bg-success rounded-pill">8.8 điểm</span>
                            </li>
                            <li class="list-group-item d-flex justify-content-between align-items-center border-0 px-0">
                                <span><i class="bi-check-circle-fill text-success me-2"></i> Tiếng Anh</span>
                                <span class="badge bg-success rounded-pill">8.2 điểm</span>
                            </li>
                            <li class="list-group-item d-flex justify-content-between align-items-center border-0 px-0">
                                <span><i class="bi-check-circle-fill text-success me-2"></i> Tư duy logic</span>
                                <span class="badge bg-success rounded-pill">85%</span>
                            </li>
                        </ul>
                    </div>
                </div>
            </div>
            <div class="col-md-6">
                <div class="card border-0 shadow-sm rounded-4">
                    <div class="card-header bg-white border-0 pt-4 px-4">
                        <h5 class="mb-0 text-danger">⚠️ Điểm yếu cần cải thiện</h5>
                    </div>
                    <div class="card-body p-4">
                        <ul class="list-group list-group-flush">
                            <li class="list-group-item d-flex justify-content-between align-items-center border-0 px-0">
                                <span><i class="bi-exclamation-triangle-fill text-danger me-2"></i> Toán cao cấp</span>
                                <span class="badge bg-danger rounded-pill">7.0 điểm</span>
                            </li>
                            <li class="list-group-item d-flex justify-content-between align-items-center border-0 px-0">
                                <span><i class="bi-exclamation-triangle-fill text-danger me-2"></i> Cơ sở dữ liệu</span>
                                <span class="badge bg-danger rounded-pill">7.5 điểm</span>
                            </li>
                            <li class="list-group-item d-flex justify-content-between align-items-center border-0 px-0">
                                <span><i class="bi-exclamation-triangle-fill text-danger me-2"></i> Kỹ năng làm bài</span>
                                <span class="badge bg-danger rounded-pill">Cần cải thiện tốc độ</span>
                            </li>
                        </ul>
                    </div>
                </div>
            </div>
        </div>

        <!-- Lời khuyên học tập -->
        <div class="card border-0 bg-info bg-opacity-10 rounded-4 mt-4">
            <div class="card-body p-4">
                <div class="row align-items-center">
                    <div class="col-md-2 text-center">
                        <i class="bi-lightbulb-fill" style="font-size: 48px; color: #ffc107;"></i>
                    </div>
                    <div class="col-md-10">
                        <h5 class="mb-2">💡 Lời khuyên học tập</h5>
                        <p class="mb-0">Dựa trên kết quả của bạn, hãy dành nhiều thời gian hơn cho môn <strong>Toán cao cấp</strong> và <strong>Cơ sở dữ liệu</strong>. Bạn có tiềm năng phát triển tốt ở mảng <strong>Lập trình Web</strong>. Hãy tiếp tục phát huy!</p>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
        <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
        <script>
            // Biểu đồ điểm theo thời gian
            new Chart(document.getElementById('scoreTrendChart'), {
                type: 'line',
                data: {
                    labels: ['Tuần 1', 'Tuần 2', 'Tuần 3', 'Tuần 4', 'Tuần 5', 'Tuần 6'],
                    datasets: [{
                        label: 'Điểm trung bình',
                        data: [6.5, 7.0, 7.8, 8.2, 8.5, 8.8],
                        borderColor: '#667eea',
                        backgroundColor: 'rgba(102, 126, 234, 0.1)',
                        tension: 0.3,
                        fill: true,
                        pointBackgroundColor: '#667eea',
                        pointBorderColor: '#fff',
                        pointRadius: 6,
                        pointHoverRadius: 8
                    }]
                },
                options: {
                    responsive: true,
                    maintainAspectRatio: true,
                    plugins: {
                        legend: { position: 'top' },
                        tooltip: { callbacks: { label: (ctx) => `Điểm: ${ctx.raw}` } }
                    },
                    scales: {
                        y: { min: 0, max: 10, title: { display: true, text: 'Điểm số' } },
                        x: { title: { display: true, text: 'Thời gian' } }
                    }
                }
            });

            // Biểu đồ phân bố điểm theo môn
            new Chart(document.getElementById('subjectChart'), {
                type: 'doughnut',
                data: {
                    labels: ['Lập trình Web', 'Cơ sở dữ liệu', 'Tiếng Anh', 'Toán cao cấp'],
                    datasets: [{
                        data: [8.8, 7.5, 8.2, 7.0],
                        backgroundColor: ['#667eea', '#f59e0b', '#10b981', '#ef4444'],
                        borderWidth: 0
                    }]
                },
                options: {
                    responsive: true,
                    maintainAspectRatio: true,
                    plugins: {
                        legend: { position: 'bottom' },
                        tooltip: { callbacks: { label: (ctx) => `${ctx.label}: ${ctx.raw} điểm` } }
                    }
                }
            });
        </script>
}
