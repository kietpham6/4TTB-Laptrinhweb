@{
    ViewData["Title"] = "Tạo đề thi";
}

<section class="intro-section section-padding" style="margin-top:120px;">
    <div class="container">
        <div class="row">
            <div class="col-lg-8 mx-auto">
                <div class="card border-0 shadow-sm rounded-4">
                    <div class="card-body p-5">
                        <h2 class="mb-4">📝 Tạo đề thi mới</h2>

                        <form>
                            <div class="mb-3"><label class="form-label">Tên đề thi</label><input type="text" class="form-control" placeholder="VD: Kiểm tra giữa kỳ"></div>
                            <div class="mb-3"><label class="form-label">Mô tả</label><textarea class="form-control" rows="3"></textarea></div>

                            <div class="row">
                                <div class="col-md-6"><div class="mb-3"><label class="form-label">Môn học</label><select class="form-select"><option>Lập trình Web</option><option>Cơ sở dữ liệu</option></select></div></div>
                                <div class="col-md-6"><div class="mb-3"><label class="form-label">Thời gian làm bài</label><select class="form-select"><option>30 phút</option><option>45 phút</option><option>60 phút</option><option>90 phút</option></select></div></div>
                            </div>

                            <div class="row">
                                <div class="col-md-6"><div class="mb-3"><label class="form-label">Ngày bắt đầu</label><input type="datetime-local" class="form-control"></div></div>
                                <div class="col-md-6"><div class="mb-3"><label class="form-label">Ngày kết thúc</label><input type="datetime-local" class="form-control"></div></div>
                            </div>

                            <h5 class="mt-3 mb-3">📊 Cấu hình đề thi</h5>
                            <div class="row">
                                <div class="col-md-4"><div class="mb-3"><label class="form-label">Số câu dễ</label><input type="number" class="form-control" value="10" min="0"></div></div>
                                <div class="col-md-4"><div class="mb-3"><label class="form-label">Số câu trung bình</label><input type="number" class="form-control" value="15" min="0"></div></div>
                                <div class="col-md-4"><div class="mb-3"><label class="form-label">Số câu khó</label><input type="number" class="form-control" value="5" min="0"></div></div>
                            </div>

                            <div class="row">
                                <div class="col-md-6"><div class="mb-3 form-check"><input type="checkbox" class="form-check-input" id="randomQ"><label class="form-check-label" for="randomQ">Trộn câu hỏi (mỗi học viên một đề)</label></div></div>
                                <div class="col-md-6"><div class="mb-3 form-check"><input type="checkbox" class="form-check-input" id="randomA"><label class="form-check-label" for="randomA">Trộn đáp án</label></div></div>
                            </div>

                            <div class="mb-3"><label class="form-label">Mật khẩu phòng thi (tùy chọn)</label><input type="text" class="form-control" placeholder="Để trống nếu không cần mật khẩu"></div>

                            <div class="d-flex justify-content-end gap-2 mt-4">
                                <a href="/Teacher/Exams" class="btn btn-secondary">Hủy</a>
                                <button type="submit" class="btn btn-primary">Tạo đề thi</button>
                            </div>
                        </form>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>