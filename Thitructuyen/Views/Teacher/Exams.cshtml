@{
    ViewData["Title"] = "Quản lý kỳ thi";
}

<div class="pro-page-title">
    <div>
        <h2>📝 Quản lý kỳ thi</h2>
        <p>Danh sách kỳ thi lấy trực tiếp từ database. Tạo đề thi dùng đúng giao diện Word/ngân hàng câu hỏi như trang giáo viên.</p>
    </div>
    <a class="btn btn-primary" asp-controller="Teacher" asp-action="CreateExam">
        <i class="bi-plus-lg me-2"></i>Tạo kỳ thi mới
    </a>
</div>

<div class="card border-0 shadow-sm rounded-4 mb-4">
    <div class="card-body p-4">
        <div class="row g-3">
            <div class="col-md-4">
                <input type="text" class="form-control" id="searchExam" placeholder="🔍 Tìm kiếm kỳ thi..." onkeyup="filterExams()">
            </div>
            <div class="col-md-3">
                <select class="form-select" id="filterExamStatus" onchange="filterExams()">
                    <option value="all">Tất cả trạng thái</option>
                    <option value="ongoing">Đang diễn ra</option>
                    <option value="upcoming">Sắp diễn ra</option>
                    <option value="ended">Đã kết thúc</option>
                </select>
            </div>
            <div class="col-md-3">
                <select class="form-select" id="filterExamSubject" onchange="filterExams()">
                    <option value="all">Tất cả môn học</option>
                </select>
            </div>
            <div class="col-md-2">
                <button class="btn btn-outline-secondary w-100" onclick="resetFilters()">⟳ Reset</button>
            </div>
        </div>
    </div>
</div>

<div class="card border-0 shadow-sm rounded-4">
    <div class="card-body p-0">
        <div class="table-responsive">
            <table class="table table-hover mb-0" id="examTable">
                <thead class="bg-light">
                    <tr>
                        <th class="ps-4">ID</th>
                        <th>Tên kỳ thi</th>
                        <th>Môn học</th>
                        <th>Thời gian</th>
                        <th>Số câu</th>
                        <th>Ngày bắt đầu</th>
                        <th>Ngày kết thúc</th>
                        <th>Số lượt thi</th>
                        <th>Điểm TB</th>
                        <th>Trạng thái</th>
                        <th class="text-center pe-4">Thao tác</th>
                    </tr>
                </thead>
                <tbody id="examTableBody">
                    <tr><td colspan="11" class="text-center text-muted py-4">Đang tải dữ liệu...</td></tr>
                </tbody>
            </table>
        </div>
    </div>
    <div class="card-footer bg-white border-0 pt-3 pb-3">
        <div class="d-flex justify-content-between align-items-center">
            <span class="text-muted" id="resultCount">📊 Đang tải...</span>
        </div>
    </div>
</div>

@section Scripts {
<script>
    let examsData = [];
    const safe = v => `${v ?? ''}`.replace(/[&<>'"]/g, m => ({'&':'&amp;','<':'&lt;','>':'&gt;',"'":'&#39;','"':'&quot;'}[m]));

    function statusClass(exam){ return exam.statusClass || (exam.status === 'ongoing' ? 'bg-success' : exam.status === 'ended' ? 'bg-secondary' : 'bg-warning'); }

    async function loadExams(){
        try {
            const res = await fetch('/api/Api/exams');
            if(!res.ok) throw new Error('Không tải được dữ liệu kỳ thi từ API');
            examsData = await res.json();
            buildSubjectFilter();
            filterExams();
        } catch(err) {
            document.getElementById('examTableBody').innerHTML = `<tr><td colspan="11" class="text-center text-danger py-4">${safe(err.message)}</td></tr>`;
            document.getElementById('resultCount').textContent = 'Không tải được dữ liệu';
        }
    }

    function buildSubjectFilter(){
        const select = document.getElementById('filterExamSubject');
        const current = select.value;
        const subjects = [...new Set(examsData.map(x => x.subject).filter(Boolean))].sort();
        select.innerHTML = '<option value="all">Tất cả môn học</option>' + subjects.map(s => `<option value="${safe(s)}">${safe(s)}</option>`).join('');
        select.value = subjects.includes(current) ? current : 'all';
    }

    function filterExams(){
        const searchValue = document.getElementById('searchExam').value.toLowerCase().trim();
        const statusValue = document.getElementById('filterExamStatus').value;
        const subjectValue = document.getElementById('filterExamSubject').value;
        const filtered = examsData.filter(exam => {
            const name = (exam.name || exam.title || '').toLowerCase();
            const matchSearch = !searchValue || name.includes(searchValue);
            const matchStatus = statusValue === 'all' || exam.status === statusValue;
            const matchSubject = subjectValue === 'all' || exam.subject === subjectValue;
            return matchSearch && matchStatus && matchSubject;
        });
        renderExamTable(filtered);
        document.getElementById('resultCount').innerHTML = `📊 Hiển thị ${filtered.length} của ${examsData.length} kỳ thi`;
    }

    function renderExamTable(exams){
        const tbody = document.getElementById('examTableBody');
        if(!exams.length){
            tbody.innerHTML = '<tr><td colspan="11" class="text-center py-4">📭 Không tìm thấy kỳ thi nào!</td></tr>';
            return;
        }
        tbody.innerHTML = exams.map(exam => `
            <tr>
                <td class="ps-4">${exam.id}</td>
                <td><b>${safe(exam.name || exam.title)}</b></td>
                <td>${safe(exam.subject || 'Chưa phân môn')}</td>
                <td>${safe(exam.durationText || ((exam.duration || 0) + ' phút'))}</td>
                <td>${exam.questions ?? exam.totalQuestions ?? 0}</td>
                <td>${safe(exam.startDate || exam.startTime)}</td>
                <td>${safe(exam.endDate || exam.endTime)}</td>
                <td>${exam.attempts ?? 0}</td>
                <td>${exam.avgScore ?? '-'}</td>
                <td><span class="badge ${statusClass(exam)}">${safe(exam.statusText || exam.status)}</span></td>
                <td class="text-center pe-4">
                    <a class="btn btn-sm btn-outline-primary me-1" href="/Exam/TakeExam/${exam.id}" title="Xem/thi"><i class="bi-eye"></i></a>
                    <button class="btn btn-sm btn-outline-danger" onclick="deleteExam(${exam.id}, '${safe(exam.name || exam.title).replace(/'/g,'&#39;')}')"><i class="bi-trash"></i></button>
                </td>
            </tr>`).join('');
    }

    function resetFilters(){
        document.getElementById('searchExam').value = '';
        document.getElementById('filterExamStatus').value = 'all';
        document.getElementById('filterExamSubject').value = 'all';
        filterExams();
    }

    async function deleteExam(id, name){
        if(!confirm(`Bạn có chắc muốn xóa kỳ thi "${name}"?`)) return;
        const res = await fetch(`/api/Api/exam/${id}`, { method: 'DELETE' });
        const data = await res.json();
        alert(data.message || (data.success ? 'Đã xóa kỳ thi' : 'Không thể xóa'));
        if(data.success) loadExams();
    }

    document.addEventListener('DOMContentLoaded', loadExams);
</script>
}
