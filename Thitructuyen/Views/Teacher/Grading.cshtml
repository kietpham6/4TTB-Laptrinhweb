@{
    ViewData["Title"] = "Chấm bài tự luận";
}

<div class="pro-page-title">
    <div>
        <h2>✏️ Chấm bài tự luận</h2>
        <p>Danh sách bài làm lấy trực tiếp từ database. Giáo viên chấm câu tự luận và hệ thống tự cập nhật tổng điểm.</p>
    </div>
</div>

<div class="chart-card mb-4">
    <div class="row g-3 align-items-end">
        <div class="col-lg-4">
            <label class="form-label">Kỳ thi</label>
            <select class="form-select" id="filterExam">
                <option value="all">Tất cả kỳ thi</option>
            </select>
        </div>
        <div class="col-lg-3">
            <label class="form-label">Trạng thái</label>
            <select class="form-select" id="filterStatus">
                <option value="all">Tất cả</option>
                <option value="pending">Chờ chấm</option>
                <option value="graded">Đã chấm</option>
            </select>
        </div>
        <div class="col-lg-3">
            <label class="form-label">Tìm học viên</label>
            <input type="text" class="form-control" id="searchStudent" placeholder="Nhập tên học viên...">
        </div>
        <div class="col-lg-2 d-grid">
            <button class="btn btn-outline-secondary" onclick="resetFilters()"><i class="bi-arrow-repeat me-1"></i>Reset</button>
        </div>
    </div>
</div>

<div class="row g-4 mb-4">
    <div class="col-md-4"><div class="metric-card"><div class="metric-icon"><i class="bi-inbox"></i></div><div class="metric-value" id="totalSubmissions">0</div><div class="metric-label">Tổng bài đã nộp</div></div></div>
    <div class="col-md-4"><div class="metric-card"><div class="metric-icon"><i class="bi-hourglass-split"></i></div><div class="metric-value" id="pendingSubmissions">0</div><div class="metric-label">Chờ chấm</div></div></div>
    <div class="col-md-4"><div class="metric-card"><div class="metric-icon"><i class="bi-check-circle"></i></div><div class="metric-value" id="gradedSubmissions">0</div><div class="metric-label">Đã chấm</div></div></div>
</div>

<div class="chart-card">
    <div class="d-flex justify-content-between align-items-center mb-3 flex-wrap gap-2">
        <h5 class="mb-0">📋 Danh sách bài làm</h5>
        <span class="badge bg-primary">Dữ liệu thật</span>
    </div>
    <div class="table-responsive">
        <table class="table table-hover align-middle mb-0">
            <thead>
                <tr>
                    <th>ID</th>
                    <th>Học viên</th>
                    <th>Kỳ thi</th>
                    <th>Môn học</th>
                    <th>Ngày nộp</th>
                    <th>Điểm</th>
                    <th>Tự luận</th>
                    <th>Trạng thái</th>
                    <th>Thao tác</th>
                </tr>
            </thead>
            <tbody id="submissionsTableBody">
                <tr><td colspan="9" class="text-center text-muted py-4">Đang tải dữ liệu...</td></tr>
            </tbody>
        </table>
    </div>
    <div class="pt-3 text-muted" id="resultCount">📊 Hiển thị 0 bài làm</div>
</div>

<div class="modal fade" id="detailModal" tabindex="-1">
    <div class="modal-dialog modal-xl modal-dialog-scrollable" style="margin-top:90px;">
        <div class="modal-content rounded-4">
            <div class="modal-header border-0 bg-primary text-white">
                <h5 class="modal-title"><i class="bi-pencil-square me-2"></i><span id="modalTitle">Chi tiết bài làm</span></h5>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body">
                <div id="attemptSummary" class="alert alert-info mb-4">Đang tải...</div>
                <div id="answersContainer" class="vstack gap-3"></div>
            </div>
            <div class="modal-footer border-0">
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Đóng</button>
                <button type="button" class="btn btn-primary" onclick="saveAllEssayScores()"><i class="bi-save me-1"></i>Lưu điểm tự luận</button>
            </div>
        </div>
    </div>
</div>

@section Scripts {
<script>
let submissionsData = [];
let currentAttemptId = null;
const safe = v => `${v ?? ''}`.replace(/[&<>'"]/g, m => ({'&':'&amp;','<':'&lt;','>':'&gt;',"'":'&#39;','"':'&quot;'}[m]));

async function loadExams(){
    try{
        const res = await fetch('/api/Api/exams');
        const exams = await res.json();
        const select = document.getElementById('filterExam');
        select.innerHTML = '<option value="all">Tất cả kỳ thi</option>' + (exams || []).map(e => `<option value="${e.id}">${safe(e.title || e.name)}</option>`).join('');
    }catch{ }
}

async function loadSubmissions(){
    const exam = document.getElementById('filterExam').value;
    const status = document.getElementById('filterStatus').value;
    const search = document.getElementById('searchStudent').value || '';
    const params = new URLSearchParams();
    if(exam !== 'all') params.set('examId', exam);
    if(status !== 'all') params.set('status', status);
    if(search.trim()) params.set('search', search.trim());
    try{
        const res = await fetch('/Teacher/SubmissionsForGrading?' + params.toString());
        if(!res.ok) throw new Error('Không tải được danh sách bài làm');
        submissionsData = await res.json();
        renderSubmissions(submissionsData);
    }catch(err){
        document.getElementById('submissionsTableBody').innerHTML = `<tr><td colspan="9" class="text-center text-danger py-4">${safe(err.message)}</td></tr>`;
    }
}

function renderSubmissions(data){
    totalSubmissions.textContent = data.length;
    pendingSubmissions.textContent = data.filter(x => x.status === 'pending').length;
    gradedSubmissions.textContent = data.filter(x => x.status === 'graded').length;
    resultCount.textContent = `📊 Hiển thị ${data.length} bài làm`;
    const body = document.getElementById('submissionsTableBody');
    if(!data.length){
        body.innerHTML = '<tr><td colspan="9" class="text-center text-muted py-4">Chưa có bài làm phù hợp</td></tr>';
        return;
    }
    body.innerHTML = data.map(x => `
        <tr>
            <td>${x.attemptId}</td>
            <td><b>${safe(x.student)}</b></td>
            <td>${safe(x.examName)}</td>
            <td>${safe(x.subject)}</td>
            <td>${safe(x.date)}</td>
            <td>${x.score === 'pending' ? '<span class="badge bg-warning text-dark">Chờ chấm</span>' : `<span class="badge bg-success">${safe(x.score)}/10</span>`}</td>
            <td>${x.essayGraded}/${x.essayTotal}</td>
            <td><span class="badge ${x.status === 'graded' ? 'bg-success' : 'bg-warning text-dark'}">${safe(x.statusText)}</span></td>
            <td><button class="btn btn-sm btn-outline-primary" onclick="openDetail(${x.attemptId})"><i class="bi-eye me-1"></i>Xem/chấm</button></td>
        </tr>`).join('');
}

async function openDetail(attemptId){
    currentAttemptId = attemptId;
    const modal = new bootstrap.Modal(document.getElementById('detailModal'));
    document.getElementById('attemptSummary').innerHTML = 'Đang tải...';
    document.getElementById('answersContainer').innerHTML = '';
    modal.show();
    try{
        const res = await fetch('/Teacher/AttemptDetail?attemptId=' + attemptId);
        const data = await res.json();
        if(!data.success) throw new Error(data.message || 'Không tải được chi tiết');
        const a = data.attempt;
        modalTitle.textContent = `Bài làm #${a.id} - ${a.student}`;
        attemptSummary.innerHTML = `<b>Học viên:</b> ${safe(a.student)} &nbsp; | &nbsp; <b>Kỳ thi:</b> ${safe(a.exam)} &nbsp; | &nbsp; <b>Môn:</b> ${safe(a.subject)}<br><b>Ngày nộp:</b> ${safe(a.submitTime)} &nbsp; | &nbsp; <b>Điểm hiện tại:</b> ${safe(a.score)}/10 &nbsp; | &nbsp; <b>Vi phạm:</b> ${a.violations}`;
        renderAnswers(data.answers || []);
    }catch(err){
        attemptSummary.innerHTML = `<span class="text-danger">${safe(err.message)}</span>`;
    }
}

function optionText(ans){ return ans ? safe(ans) : '<span class="text-muted">Không trả lời</span>'; }
function renderAnswers(answers){
    const wrap = document.getElementById('answersContainer');
    if(!answers.length){ wrap.innerHTML = '<div class="text-muted">Không có câu trả lời.</div>'; return; }
    wrap.innerHTML = answers.map((x, i) => {
        const isEssay = (x.type || '').toLowerCase().includes('tự luận');
        return `<div class="border rounded-4 p-3 bg-white" data-answer-id="${x.answerId}" data-is-essay="${isEssay}">
            <div class="d-flex justify-content-between gap-2 flex-wrap mb-2">
                <h6 class="mb-0">Câu ${i + 1}: ${safe(x.question)}</h6>
                <span class="badge ${isEssay ? 'bg-warning text-dark' : (x.isCorrect ? 'bg-success' : 'bg-danger')}">${safe(x.type || 'Câu hỏi')}</span>
            </div>
            <div class="row g-3">
                <div class="col-md-8">
                    <div><b>Câu trả lời:</b> ${optionText(x.selectedAnswer)}</div>
                    ${!isEssay ? `<div class="mt-2"><b>Đáp án đúng:</b> ${safe(x.correctAnswer)}</div>` : ''}
                    ${x.optionA || x.optionB || x.optionC || x.optionD ? `<div class="small text-muted mt-2">A. ${safe(x.optionA)} &nbsp; B. ${safe(x.optionB)} &nbsp; C. ${safe(x.optionC)} &nbsp; D. ${safe(x.optionD)}</div>` : ''}
                </div>
                <div class="col-md-4">
                    ${isEssay ? `<label class="form-label">Điểm / ${x.maxPoints}</label><input type="number" class="form-control essay-score" min="0" max="${x.maxPoints}" step="0.25" value="${x.essayScore ?? ''}"><label class="form-label mt-2">Nhận xét</label><textarea class="form-control essay-comment" rows="2">${safe(x.teacherComment)}</textarea>` : `<span class="badge ${x.isCorrect ? 'bg-success' : 'bg-danger'}">${x.isCorrect ? 'Đúng' : 'Sai'}</span>`}
                </div>
            </div>
        </div>`;
    }).join('');
}

async function saveAllEssayScores(){
    const blocks = [...document.querySelectorAll('#answersContainer [data-is-essay="true"]')];
    if(!blocks.length){ alert('Bài này không có câu tự luận để chấm.'); return; }
    for(const block of blocks){
        const answerId = block.getAttribute('data-answer-id');
        const score = block.querySelector('.essay-score').value;
        const comment = block.querySelector('.essay-comment').value || '';
        if(score === ''){ alert('Vui lòng nhập điểm cho tất cả câu tự luận.'); return; }
        const form = new URLSearchParams();
        form.set('answerId', answerId);
        form.set('score', score);
        form.set('comment', comment);
        const res = await fetch('/Teacher/GradeEssay', { method:'POST', headers:{'Content-Type':'application/x-www-form-urlencoded'}, body: form.toString() });
        const data = await res.json();
        if(!data.success){ alert(data.message || 'Lưu điểm thất bại'); return; }
    }
    alert('Đã lưu điểm tự luận và cập nhật tổng điểm.');
    await loadSubmissions();
    if(currentAttemptId) openDetail(currentAttemptId);
}

function resetFilters(){
    filterExam.value = 'all'; filterStatus.value = 'all'; searchStudent.value = '';
    loadSubmissions();
}

filterExam.addEventListener('change', loadSubmissions);
filterStatus.addEventListener('change', loadSubmissions);
searchStudent.addEventListener('input', () => { clearTimeout(window.__gradingTimer); window.__gradingTimer = setTimeout(loadSubmissions, 350); });
loadExams().then(loadSubmissions);
</script>
}
