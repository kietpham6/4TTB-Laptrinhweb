@{
    ViewData["Title"] = "Giám sát Anti-cheat";
}
<div class="pro-page-title">
    <div>
        <h2>👁️ Giám sát Anti-cheat</h2>
        <p>Theo dõi toàn bộ cảnh báo gian lận được ghi nhận trong quá trình làm bài.</p>
    </div>
    <button class="btn btn-outline-primary" type="button" onclick="loadLogs()"><i class="bi-arrow-clockwise me-1"></i> Tải lại</button>
</div>

<div class="alert alert-info rounded-4">
    Hệ thống đang bật Anti-cheat: phát hiện chuyển tab, thoát toàn màn hình, mất focus, chặn chuột phải, chặn copy/cut/paste, chặn phím tắt nguy hiểm, ghi log vi phạm và hỗ trợ nộp bài tự động khi vượt ngưỡng.
</div>

<div class="row g-4 mb-4">
    <div class="col-md-4"><div class="metric-card"><div class="metric-icon"><i class="bi-shield-exclamation"></i></div><div class="metric-value" id="totalViolations">0</div><div class="metric-label">Tổng cảnh báo</div></div></div>
    <div class="col-md-4"><div class="metric-card"><div class="metric-icon"><i class="bi-people"></i></div><div class="metric-value" id="totalStudents">0</div><div class="metric-label">Học sinh liên quan</div></div></div>
    <div class="col-md-4"><div class="metric-card"><div class="metric-icon"><i class="bi-clock-history"></i></div><div class="metric-value" id="latestTime">-</div><div class="metric-label">Vi phạm mới nhất</div></div></div>
</div>

<div class="chart-card">
    <div class="d-flex flex-wrap justify-content-between align-items-center gap-2 mb-3">
        <h5 class="mb-0">📋 Danh sách cảnh báo</h5>
        <input id="searchBox" class="form-control" style="max-width:360px" placeholder="Tìm học sinh, nội dung, IP..." oninput="renderLogs()">
    </div>
    <div class="table-responsive">
        <table class="table table-hover align-middle table-pro">
            <thead><tr><th>#</th><th>Thời gian</th><th>Học sinh</th><th>UserId</th><th>Chi tiết</th><th>IP</th></tr></thead>
            <tbody id="body"><tr><td colspan="6" class="text-center text-muted py-4">Đang tải dữ liệu...</td></tr></tbody>
        </table>
    </div>
</div>

@section Scripts{
<script>
let logs = [];
const esc = v => `${v ?? ''}`.replace(/[&<>'"]/g, m => ({'&':'&amp;','<':'&lt;','>':'&gt;',"'":'&#39;','"':'&quot;'}[m]));
function renderLogs(){
    const keyword = (document.getElementById('searchBox')?.value || '').toLowerCase().trim();
    const data = keyword ? logs.filter(x => `${x.userName||''} ${x.userId||''} ${x.detail||''} ${x.ipAddress||''}`.toLowerCase().includes(keyword)) : logs;
    document.getElementById('totalViolations').textContent = logs.length;
    document.getElementById('totalStudents').textContent = new Set(logs.map(x => x.userId).filter(Boolean)).size;
    document.getElementById('latestTime').textContent = logs.length ? logs[0].createdAt : '-';
    const body = document.getElementById('body');
    if(!data.length){
        body.innerHTML = '<tr><td colspan="6" class="text-center text-muted py-4">Chưa có cảnh báo gian lận</td></tr>';
        return;
    }
    body.innerHTML = data.map((x,i)=>`<tr>
        <td>${i+1}</td>
        <td>${esc(x.createdAt)}</td>
        <td><b>${esc(x.userName || 'Không xác định')}</b></td>
        <td>${esc(x.userId ?? '')}</td>
        <td><span class="badge bg-danger me-2">Violation</span>${esc(x.detail)}</td>
        <td>${esc(x.ipAddress || '')}</td>
    </tr>`).join('');
}
function loadLogs(){
    const body = document.getElementById('body');
    body.innerHTML = '<tr><td colspan="6" class="text-center text-muted py-4">Đang tải dữ liệu...</td></tr>';
    fetch('/api/dashboard/audit-logs?action=Violation', { cache:'no-store' })
        .then(r => { if(!r.ok) throw new Error('Không có quyền hoặc API lỗi'); return r.json(); })
        .then(data => { logs = Array.isArray(data) ? data : []; renderLogs(); })
        .catch(err => { body.innerHTML = `<tr><td colspan="6" class="text-center text-danger py-4">${esc(err.message)}</td></tr>`; });
}
loadLogs();
</script>
}
