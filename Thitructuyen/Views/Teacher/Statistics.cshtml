@{ ViewData["Title"] = "Thống kê nâng cao"; }
<div class="pro-page-title"><div><h2>📊 Thống kê nâng cao</h2><p>Tất cả số liệu lấy từ database: lượt thi, điểm số, tỷ lệ đạt và thống kê theo môn.</p></div></div>
<div class="row g-4 mb-4">
 <div class="col-md-3"><div class="metric-card"><div class="metric-icon"><i class="bi-people"></i></div><div class="metric-value" id="totalUsers">0</div><div class="metric-label">Người dùng</div></div></div>
 <div class="col-md-3"><div class="metric-card"><div class="metric-icon"><i class="bi-file-earmark-text"></i></div><div class="metric-value" id="totalExams">0</div><div class="metric-label">Kỳ thi</div></div></div>
 <div class="col-md-3"><div class="metric-card"><div class="metric-icon"><i class="bi-pencil-square"></i></div><div class="metric-value" id="totalAttempts">0</div><div class="metric-label">Lượt thi đã chấm</div></div></div>
 <div class="col-md-3"><div class="metric-card"><div class="metric-icon"><i class="bi-check-circle"></i></div><div class="metric-value"><span id="passRate">0</span>%</div><div class="metric-label">Tỷ lệ đạt</div></div></div>
</div>
<div class="row g-4 mb-4">
 <div class="col-xl-6"><div class="chart-card"><h5 class="mb-3">📈 Phân bố điểm</h5><canvas id="scoreDist" height="150"></canvas></div></div>
 <div class="col-xl-6"><div class="chart-card"><h5 class="mb-3">🏆 Top học sinh</h5><div class="table-responsive"><table class="table table-hover"><thead><tr><th>Hạng</th><th>Học sinh</th><th>Lượt thi</th><th>Điểm TB</th><th>Cao nhất</th></tr></thead><tbody id="topRows"></tbody></table></div></div></div>
</div>
<div class="chart-card"><h5 class="mb-3">📚 Theo môn học</h5><div class="table-responsive"><table class="table table-hover"><thead><tr><th>Môn học</th><th>Số đề</th><th>Lượt thi</th><th>Điểm TB</th><th>Tỷ lệ đạt</th></tr></thead><tbody id="subjectRows"></tbody></table></div></div>
@section Scripts{
<script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
<script>
Promise.all([fetch('/api/Api/statistics/overview').then(r=>r.json()), fetch('/api/Api/statistics/top-students').then(r=>r.json()), fetch('/api/Api/statistics/by-subject').then(r=>r.json())]).then(([o,top,subs])=>{
 totalUsers.textContent=o.totalUsers||0; totalExams.textContent=o.totalExams||0; totalAttempts.textContent=o.totalAttempts||0; passRate.textContent=o.passRate||0;
 if(window.Chart) new Chart(document.getElementById('scoreDist'),{type:'bar',data:{labels:['0-2','2-4','4-6','6-8','8-10'],datasets:[{label:'Số lượt',data:o.scoreDistribution||[]}]},options:{responsive:true,scales:{y:{beginAtZero:true}}}});
 topRows.innerHTML=(top||[]).map(x=>`<tr><td>#${x.rank}</td><td><b>${x.name}</b></td><td>${x.exams}</td><td><b>${x.avgScore}</b>/10</td><td>${x.highest}</td></tr>`).join('')||'<tr><td colspan="5" class="text-muted text-center py-4">Chưa có dữ liệu</td></tr>';
 subjectRows.innerHTML=(subs||[]).map(x=>`<tr><td><b>${x.subject}</b></td><td>${x.exams}</td><td>${x.attempts}</td><td>${x.avgScore}/10</td><td>${x.passRate}%</td></tr>`).join('')||'<tr><td colspan="5" class="text-muted text-center py-4">Chưa có dữ liệu</td></tr>';
});
</script>
}
